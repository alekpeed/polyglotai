[
  { "schemaVersion": 1, "key": "vocab.shumi", "entryType": "word", "lemma": "趣味", "reading": "しゅみ", "romaji": "shumi", "translation": "hobby", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "tags": ["life"], "examples": [{ "text": "趣味は音楽です。", "reading": "しゅみはおんがくです。", "romaji": "Shumi wa ongaku desu.", "translation": "My hobby is music." }] },
  { "schemaVersion": 1, "key": "vocab.ongaku", "entryType": "word", "lemma": "音楽", "reading": "おんがく", "romaji": "ongaku", "translation": "music", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "tags": ["life"] },
  { "schemaVersion": 1, "key": "vocab.eiga", "entryType": "word", "lemma": "映画", "reading": "えいが", "romaji": "eiga", "translation": "movie / film", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "tags": ["life"] },
  { "schemaVersion": 1, "key": "vocab.ryokou", "entryType": "word", "lemma": "旅行", "reading": "りょこう", "romaji": "ryokou", "translation": "trip / travel", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "tags": ["life", "travel"], "naturalMeaning": "旅行する ('to travel') is a する-verb. 旅行に行く ('go on a trip') is equally common." },
  { "schemaVersion": 1, "key": "vocab.ryouri", "entryType": "word", "lemma": "料理", "reading": "りょうり", "romaji": "ryouri", "translation": "cooking / a dish", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "tags": ["food-drink", "life"], "naturalMeaning": "Both the activity (料理をする, 'to cook') and the result (a cuisine or dish — 日本料理, 'Japanese food')." },
  { "schemaVersion": 1, "key": "vocab.kaimono", "entryType": "word", "lemma": "買い物", "reading": "かいもの", "romaji": "kaimono", "translation": "shopping", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "tags": ["life"], "naturalMeaning": "Built from 買う (to buy) + 物 (thing). 買い物をする / 買い物に行く are the usual ways to say 'go shopping'." },
  { "schemaVersion": 1, "key": "vocab.supootsu", "entryType": "word", "lemma": "スポーツ", "romaji": "supootsu", "translation": "sport(s)", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "tags": ["life"] },
  { "schemaVersion": 1, "key": "vocab.yotei", "entryType": "word", "lemma": "予定", "reading": "よてい", "romaji": "yotei", "translation": "plan / schedule", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "tags": ["life", "work"] },
  { "schemaVersion": 1, "key": "vocab.yakusoku", "entryType": "word", "lemma": "約束", "reading": "やくそく", "romaji": "yakusoku", "translation": "promise / appointment", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "tags": ["life"] },
  { "schemaVersion": 1, "key": "vocab.mondai", "entryType": "word", "lemma": "問題", "reading": "もんだい", "romaji": "mondai", "translation": "problem / question", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "tags": ["life"], "naturalMeaning": "問題ない ('no problem') is an extremely common reassurance, like the English phrase." },
  { "schemaVersion": 1, "key": "vocab.riyuu", "entryType": "word", "lemma": "理由", "reading": "りゆう", "romaji": "riyuu", "translation": "reason", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "tags": ["life"] },
  { "schemaVersion": 1, "key": "vocab.imi", "entryType": "word", "lemma": "意味", "reading": "いみ", "romaji": "imi", "translation": "meaning", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "tags": ["language"], "examples": [{ "text": "これはどういう意味ですか。", "reading": "これはどういういみですか。", "romaji": "Kore wa dou iu imi desu ka.", "translation": "What does this mean?" }] },
  { "schemaVersion": 1, "key": "vocab.kimochi", "entryType": "word", "lemma": "気持ち", "reading": "きもち", "romaji": "kimochi", "translation": "feeling / mood", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "tags": ["life"], "naturalMeaning": "気持ちいい ('feels good') is a set phrase for physical pleasantness — a breeze, a hot spring, a stretch." },
  { "schemaVersion": 1, "key": "vocab.byouki", "entryType": "word", "lemma": "病気", "reading": "びょうき", "romaji": "byouki", "translation": "illness / sick", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "tags": ["health"], "naturalMeaning": "Used with な to modify a noun or with です — 病気です means 'I'm sick'." },
  { "schemaVersion": 1, "key": "vocab.seikatsu", "entryType": "word", "lemma": "生活", "reading": "せいかつ", "romaji": "seikatsu", "translation": "daily life / living", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "tags": ["life"] },
  { "schemaVersion": 1, "key": "vocab.bunka", "entryType": "word", "lemma": "文化", "reading": "ぶんか", "romaji": "bunka", "translation": "culture", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "tags": ["life"] },
  { "schemaVersion": 1, "key": "vocab.hajimeru", "entryType": "word", "lemma": "始める", "reading": "はじめる", "romaji": "hajimeru", "translation": "to begin / start (something)", "partOfSpeech": "verb", "cefr": "A2", "register": "neutral", "tags": ["verb"], "naturalMeaning": "Transitive — you start something (授業を始める). Its intransitive partner 始まる (hajimaru) is for something that starts on its own (授業が始まる)." },
  { "schemaVersion": 1, "key": "vocab.hajimaru", "entryType": "word", "lemma": "始まる", "reading": "はじまる", "romaji": "hajimaru", "translation": "to begin / start (on its own)", "partOfSpeech": "verb", "cefr": "A2", "register": "neutral", "tags": ["verb"], "naturalMeaning": "Intransitive counterpart of 始める — the transitive/intransitive verb pair is a core A2 pattern with no clean English equivalent." },
  { "schemaVersion": 1, "key": "vocab.owaru", "entryType": "word", "lemma": "終わる", "reading": "おわる", "romaji": "owaru", "translation": "to end / finish", "partOfSpeech": "verb", "cefr": "A2", "register": "neutral", "tags": ["verb"] },
  { "schemaVersion": 1, "key": "vocab.kimeru", "entryType": "word", "lemma": "決める", "reading": "きめる", "romaji": "kimeru", "translation": "to decide", "partOfSpeech": "verb", "cefr": "A2", "register": "neutral", "tags": ["verb"] },
  { "schemaVersion": 1, "key": "vocab.sagasu", "entryType": "word", "lemma": "探す", "reading": "さがす", "romaji": "sagasu", "translation": "to look for / search", "partOfSpeech": "verb", "cefr": "A2", "register": "neutral", "tags": ["verb"] },
  { "schemaVersion": 1, "key": "vocab.erabu", "entryType": "word", "lemma": "選ぶ", "reading": "えらぶ", "romaji": "erabu", "translation": "to choose", "partOfSpeech": "verb", "cefr": "A2", "register": "neutral", "tags": ["verb"] },
  { "schemaVersion": 1, "key": "vocab.kotaeru", "entryType": "word", "lemma": "答える", "reading": "こたえる", "romaji": "kotaeru", "translation": "to answer", "partOfSpeech": "verb", "cefr": "A2", "register": "neutral", "tags": ["verb"], "naturalMeaning": "Takes に for what's answered: 質問に答える ('answer the question')." },
  { "schemaVersion": 1, "key": "vocab.tetsudau", "entryType": "word", "lemma": "手伝う", "reading": "てつだう", "romaji": "tetsudau", "translation": "to help", "partOfSpeech": "verb", "cefr": "A2", "register": "neutral", "tags": ["verb"], "examples": [{ "text": "手伝いましょうか。", "reading": "てつだいましょうか。", "romaji": "Tetsudaimashou ka.", "translation": "Shall I help you?" }] },
  { "schemaVersion": 1, "key": "vocab.tsutaeru", "entryType": "word", "lemma": "伝える", "reading": "つたえる", "romaji": "tsutaeru", "translation": "to convey / tell / pass on", "partOfSpeech": "verb", "cefr": "A2", "register": "neutral", "tags": ["verb"] },
  { "schemaVersion": 1, "key": "vocab.yoyaku-suru", "entryType": "word", "lemma": "予約する", "reading": "よやくする", "romaji": "yoyaku suru", "translation": "to reserve / book", "partOfSpeech": "verb", "cefr": "A2", "register": "neutral", "tags": ["verb", "travel"] },
  { "schemaVersion": 1, "key": "vocab.junbi-suru", "entryType": "word", "lemma": "準備する", "reading": "じゅんびする", "romaji": "junbi suru", "translation": "to prepare", "partOfSpeech": "verb", "cefr": "A2", "register": "neutral", "tags": ["verb"] },
  { "schemaVersion": 1, "key": "vocab.shinpai-suru", "entryType": "word", "lemma": "心配する", "reading": "しんぱいする", "romaji": "shinpai suru", "translation": "to worry", "partOfSpeech": "verb", "cefr": "A2", "register": "neutral", "tags": ["verb"], "naturalMeaning": "心配しないで ('don't worry') is a common reassurance to a friend." },
  { "schemaVersion": 1, "key": "vocab.kangaeru", "entryType": "word", "lemma": "考える", "reading": "かんがえる", "romaji": "kangaeru", "translation": "to think / consider", "partOfSpeech": "verb", "cefr": "A2", "register": "neutral", "tags": ["verb"], "naturalMeaning": "考える is active, deliberate thinking (weighing options); 思う is more a held opinion or feeling. English blurs both into 'think'." },
  { "schemaVersion": 1, "key": "vocab.oboeru", "entryType": "word", "lemma": "覚える", "reading": "おぼえる", "romaji": "oboeru", "translation": "to memorize / remember", "partOfSpeech": "verb", "cefr": "A2", "register": "neutral", "tags": ["verb"], "naturalMeaning": "覚える is committing to memory; 忘れる (wasureru) is forgetting. 'To recall in the moment' is 思い出す (omoidasu)." },
  { "schemaVersion": 1, "key": "vocab.wasureru", "entryType": "word", "lemma": "忘れる", "reading": "わすれる", "romaji": "wasureru", "translation": "to forget", "partOfSpeech": "verb", "cefr": "A2", "register": "neutral", "tags": ["verb"] },
  { "schemaVersion": 1, "key": "vocab.tomaru", "entryType": "word", "lemma": "止まる", "reading": "とまる", "romaji": "tomaru", "translation": "to stop (come to a stop)", "partOfSpeech": "verb", "cefr": "A2", "register": "neutral", "tags": ["verb"], "naturalMeaning": "Intransitive — 電車が止まる ('the train stops'). The transitive 止める (tomeru) is 'to stop/park something'." },
  { "schemaVersion": 1, "key": "vocab.akeru", "entryType": "word", "lemma": "開ける", "reading": "あける", "romaji": "akeru", "translation": "to open (something)", "partOfSpeech": "verb", "cefr": "A2", "register": "neutral", "tags": ["verb"], "naturalMeaning": "Transitive — ドアを開ける ('open the door'). Its pair 開く (aku) means a door 'opens' by itself." },
  { "schemaVersion": 1, "key": "vocab.shimeru", "entryType": "word", "lemma": "閉める", "reading": "しめる", "romaji": "shimeru", "translation": "to close (something)", "partOfSpeech": "verb", "cefr": "A2", "register": "neutral", "tags": ["verb"], "naturalMeaning": "Transitive partner of 閉まる (shimaru, 'to close on its own'), mirroring 開ける/開く." },
  { "schemaVersion": 1, "key": "vocab.ganbaru", "entryType": "word", "lemma": "頑張る", "reading": "がんばる", "romaji": "ganbaru", "translation": "to do one's best / hang in there", "partOfSpeech": "verb", "cefr": "A2", "register": "neutral", "tags": ["verb"], "naturalMeaning": "Culturally huge — 頑張って (ganbatte) is the everyday 'good luck / you've got this', with no single English match." },
  { "schemaVersion": 1, "key": "vocab.taisetsu", "entryType": "word", "lemma": "大切", "reading": "たいせつ", "romaji": "taisetsu", "translation": "important / precious", "partOfSpeech": "adjective", "cefr": "A2", "register": "neutral", "tags": ["adjective"], "naturalMeaning": "A な-adjective. Warmer than 重要 (juuyou, 'important') — 大切 carries a sense of something cherished." },
  { "schemaVersion": 1, "key": "vocab.kantan", "entryType": "word", "lemma": "簡単", "reading": "かんたん", "romaji": "kantan", "translation": "easy / simple", "partOfSpeech": "adjective", "cefr": "A2", "register": "neutral", "tags": ["adjective"] },
  { "schemaVersion": 1, "key": "vocab.shinsetsu", "entryType": "word", "lemma": "親切", "reading": "しんせつ", "romaji": "shinsetsu", "translation": "kind / helpful", "partOfSpeech": "adjective", "cefr": "A2", "register": "neutral", "tags": ["adjective"], "naturalMeaning": "A な-adjective for kindness shown through actions; 優しい (yasashii) is more about a gentle disposition." },
  { "schemaVersion": 1, "key": "vocab.taihen", "entryType": "word", "lemma": "大変", "reading": "たいへん", "romaji": "taihen", "translation": "tough / awful / very", "partOfSpeech": "adjective", "cefr": "A2", "register": "neutral", "tags": ["adjective"], "naturalMeaning": "As a な-adjective it means 'rough/hard' (大変な仕事); as an adverb, an intensifier like 'very' (大変おいしい). 大変ですね is a standard sympathetic 'that sounds rough'." },
  { "schemaVersion": 1, "key": "vocab.zannen", "entryType": "word", "lemma": "残念", "reading": "ざんねん", "romaji": "zannen", "translation": "regrettable / a shame", "partOfSpeech": "adjective", "cefr": "A2", "register": "neutral", "tags": ["adjective"], "naturalMeaning": "残念ですね is the go-to 'that's too bad / what a shame' when hearing disappointing news." },
  { "schemaVersion": 1, "key": "vocab.ureshii", "entryType": "word", "lemma": "うれしい", "romaji": "ureshii", "translation": "happy / glad", "partOfSpeech": "adjective", "cefr": "A2", "register": "neutral", "tags": ["adjective"], "naturalMeaning": "うれしい is momentary gladness about something specific; 楽しい (tanoshii) is 'fun/enjoyable' over a stretch of time." },
  { "schemaVersion": 1, "key": "vocab.kanashii", "entryType": "word", "lemma": "悲しい", "reading": "かなしい", "romaji": "kanashii", "translation": "sad", "partOfSpeech": "adjective", "cefr": "A2", "register": "neutral", "tags": ["adjective"] },
  { "schemaVersion": 1, "key": "vocab.kowai", "entryType": "word", "lemma": "怖い", "reading": "こわい", "romaji": "kowai", "translation": "scary / frightened", "partOfSpeech": "adjective", "cefr": "A2", "register": "neutral", "tags": ["adjective"], "naturalMeaning": "Covers both 'is scary' and 'I'm scared' — 犬が怖い can mean the dog is frightening or that I fear dogs." },
  { "schemaVersion": 1, "key": "vocab.itai", "entryType": "word", "lemma": "痛い", "reading": "いたい", "romaji": "itai", "translation": "painful / it hurts", "partOfSpeech": "adjective", "cefr": "A2", "register": "neutral", "tags": ["adjective", "health"], "naturalMeaning": "頭が痛い ('my head hurts') is how you describe pain — the body part takes が and 痛い does the work." },
  { "schemaVersion": 1, "key": "vocab.sugoi", "entryType": "word", "lemma": "すごい", "romaji": "sugoi", "translation": "amazing / awesome", "partOfSpeech": "adjective", "cefr": "A2", "register": "neutral", "tags": ["adjective"], "naturalMeaning": "Hugely common in casual speech as an all-purpose 'wow / awesome', often flattened to すごっ or used adverbially as すごく ('really')." },
  { "schemaVersion": 1, "key": "vocab.totemo", "entryType": "word", "lemma": "とても", "romaji": "totemo", "translation": "very", "partOfSpeech": "adverb", "cefr": "A2", "register": "neutral", "tags": ["adverb"], "examples": [{ "text": "とてもおいしいです。", "romaji": "Totemo oishii desu.", "translation": "It's very delicious." }] },
  { "schemaVersion": 1, "key": "vocab.amari", "entryType": "word", "lemma": "あまり", "romaji": "amari", "translation": "not very (with negative)", "partOfSpeech": "adverb", "cefr": "A2", "register": "neutral", "tags": ["adverb"], "naturalMeaning": "Pairs with a negative verb: あまり好きじゃない ('don't like it much'). Using あまり with a positive is ungrammatical." },
  { "schemaVersion": 1, "key": "vocab.zenzen", "entryType": "word", "lemma": "全然", "reading": "ぜんぜん", "romaji": "zenzen", "translation": "not at all (with negative)", "partOfSpeech": "adverb", "cefr": "A2", "register": "neutral", "tags": ["adverb"], "naturalMeaning": "Traditionally requires a negative (全然わからない, 'don't understand at all'), though casual speech now also uses it positively for 'totally' (全然いい)." },
  { "schemaVersion": 1, "key": "vocab.takusan", "entryType": "word", "lemma": "たくさん", "romaji": "takusan", "translation": "a lot / many", "partOfSpeech": "adverb", "cefr": "A2", "register": "neutral", "tags": ["adverb"] },
  { "schemaVersion": 1, "key": "vocab.sukoshi", "entryType": "word", "lemma": "少し", "reading": "すこし", "romaji": "sukoshi", "translation": "a little / a few", "partOfSpeech": "adverb", "cefr": "A2", "register": "neutral", "tags": ["adverb"], "naturalMeaning": "少し is the neutral 'a little'; ちょっと (chotto) is its more casual, softer-sounding cousin, also used to hedge or decline." },
  { "schemaVersion": 1, "key": "vocab.motto", "entryType": "word", "lemma": "もっと", "romaji": "motto", "translation": "more", "partOfSpeech": "adverb", "cefr": "A2", "register": "neutral", "tags": ["adverb"] },
  { "schemaVersion": 1, "key": "vocab.ichiban", "entryType": "word", "lemma": "一番", "reading": "いちばん", "romaji": "ichiban", "translation": "the most / number one", "partOfSpeech": "adverb", "cefr": "A2", "register": "neutral", "tags": ["adverb"], "naturalMeaning": "The everyday superlative: 一番好き ('like the most'). Literally 'number one', so it also means 'first/best' as a noun." },
  { "schemaVersion": 1, "key": "vocab.tokidoki", "entryType": "word", "lemma": "時々", "reading": "ときどき", "romaji": "tokidoki", "translation": "sometimes", "partOfSpeech": "adverb", "cefr": "A2", "register": "neutral", "tags": ["adverb"] },
  { "schemaVersion": 1, "key": "vocab.tabun", "entryType": "word", "lemma": "たぶん", "romaji": "tabun", "translation": "probably / maybe", "partOfSpeech": "adverb", "cefr": "A2", "register": "neutral", "tags": ["adverb"], "naturalMeaning": "Often pairs with でしょう or と思う at the end: たぶん来ると思います ('I think they'll probably come')." },
  { "schemaVersion": 1, "key": "vocab.issho-ni", "entryType": "word", "lemma": "一緒に", "reading": "いっしょに", "romaji": "issho ni", "translation": "together", "partOfSpeech": "adverb", "cefr": "A2", "register": "neutral", "tags": ["adverb"], "examples": [{ "text": "一緒に行きましょう。", "reading": "いっしょにいきましょう。", "romaji": "Issho ni ikimashou.", "translation": "Let's go together." }] },
  { "schemaVersion": 1, "key": "vocab.dakara", "entryType": "word", "lemma": "だから", "romaji": "dakara", "translation": "so / therefore", "partOfSpeech": "conjunction", "cefr": "A2", "register": "neutral", "tags": ["conjunction"], "naturalMeaning": "Casual/neutral 'that's why'. The more formal written equivalent is ですから or したがって." },
  { "schemaVersion": 1, "key": "vocab.demo", "entryType": "word", "lemma": "でも", "romaji": "demo", "translation": "but / however", "partOfSpeech": "conjunction", "cefr": "A2", "register": "neutral", "tags": ["conjunction"], "naturalMeaning": "Starts a sentence to push back ('But...'). Mid-sentence 'but' is usually が or けど instead." },
  { "schemaVersion": 1, "key": "vocab.soshite", "entryType": "word", "lemma": "そして", "romaji": "soshite", "translation": "and then / and also", "partOfSpeech": "conjunction", "cefr": "A2", "register": "neutral", "tags": ["conjunction"] },
  { "schemaVersion": 1, "key": "vocab.tatoeba", "entryType": "word", "lemma": "例えば", "reading": "たとえば", "romaji": "tatoeba", "translation": "for example", "partOfSpeech": "conjunction", "cefr": "A2", "register": "neutral", "tags": ["conjunction"] }
]
