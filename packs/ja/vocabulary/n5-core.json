[
  { "schemaVersion": 1, "key": "vocab.konnichiwa", "entryType": "word", "lemma": "こんにちは", "romaji": "konnichiwa", "translation": "hello / good afternoon", "partOfSpeech": "interjection", "cefr": "A1", "register": "neutral", "tags": ["greeting"], "examples": [{ "text": "こんにちは、元気ですか？", "romaji": "Konnichiwa, genki desu ka?", "translation": "Hello, how are you?" }] },
  { "schemaVersion": 1, "key": "vocab.ohayou-gozaimasu", "entryType": "word", "lemma": "おはようございます", "romaji": "ohayou gozaimasu", "translation": "good morning", "partOfSpeech": "interjection", "cefr": "A1", "register": "neutral", "tags": ["greeting"], "naturalMeaning": "Drop 'gozaimasu' (just おはよう) with friends or family — that's the casual form.", "examples": [{ "text": "おはようございます、先生。", "romaji": "Ohayou gozaimasu, sensei.", "translation": "Good morning, teacher." }] },
  { "schemaVersion": 1, "key": "vocab.konbanwa", "entryType": "word", "lemma": "こんばんは", "romaji": "konbanwa", "translation": "good evening", "partOfSpeech": "interjection", "cefr": "A1", "register": "neutral", "tags": ["greeting"] },
  { "schemaVersion": 1, "key": "vocab.sayounara", "entryType": "word", "lemma": "さようなら", "romaji": "sayounara", "translation": "goodbye", "partOfSpeech": "interjection", "cefr": "A1", "register": "neutral", "tags": ["greeting"], "naturalMeaning": "Sounds more final/formal than English 'bye' — day to day, people say じゃあね or またね instead." },
  { "schemaVersion": 1, "key": "vocab.jaa-ne", "entryType": "word", "lemma": "じゃあね", "romaji": "jaa ne", "translation": "see you / bye (casual)", "partOfSpeech": "interjection", "cefr": "A1", "register": "informal", "tags": ["greeting"], "examples": [{ "text": "じゃあね、また明日！", "romaji": "Jaa ne, mata ashita!", "translation": "See you, tomorrow!", "register": "informal" }] },
  { "schemaVersion": 1, "key": "vocab.arigatou-gozaimasu", "entryType": "word", "lemma": "ありがとうございます", "romaji": "arigatou gozaimasu", "translation": "thank you", "partOfSpeech": "interjection", "cefr": "A1", "register": "neutral", "tags": ["courtesy"], "naturalMeaning": "ありがとう alone (no ございます) is the everyday casual version, used with friends." },
  { "schemaVersion": 1, "key": "vocab.sumimasen", "entryType": "word", "lemma": "すみません", "romaji": "sumimasen", "translation": "excuse me / sorry", "partOfSpeech": "interjection", "cefr": "A1", "register": "neutral", "tags": ["courtesy"], "naturalMeaning": "Does double duty as 'excuse me' (getting attention) and a light 'sorry' — one of the most useful words in the language.", "examples": [{ "text": "すみません、駅はどこですか？", "romaji": "Sumimasen, eki wa doko desu ka?", "translation": "Excuse me, where is the station?" }] },
  { "schemaVersion": 1, "key": "vocab.hai", "entryType": "word", "lemma": "はい", "romaji": "hai", "translation": "yes", "partOfSpeech": "interjection", "cefr": "A1", "register": "neutral", "tags": ["basics"] },
  { "schemaVersion": 1, "key": "vocab.iie", "entryType": "word", "lemma": "いいえ", "romaji": "iie", "translation": "no", "partOfSpeech": "interjection", "cefr": "A1", "register": "neutral", "tags": ["basics"], "naturalMeaning": "Often softened or avoided outright — direct refusal is less common than in English; a vague ちょっと... ('a bit...') does a lot of work instead." },
  { "schemaVersion": 1, "key": "vocab.watashi", "entryType": "word", "lemma": "私", "reading": "わたし", "romaji": "watashi", "translation": "I / me", "partOfSpeech": "pronoun", "cefr": "A1", "register": "neutral", "tags": ["basics", "people"], "naturalMeaning": "Japanese drops pronouns constantly once context is clear — using 私 in every sentence the way English needs 'I' sounds stilted." },
  { "schemaVersion": 1, "key": "vocab.anata", "entryType": "word", "lemma": "あなた", "romaji": "anata", "translation": "you", "partOfSpeech": "pronoun", "cefr": "A1", "register": "neutral", "tags": ["basics", "people"], "naturalMeaning": "Natural speech uses the person's name or title instead of あなた, which can sound distant or even pointed between people who know each other." },
  { "schemaVersion": 1, "key": "vocab.namae", "entryType": "word", "lemma": "名前", "reading": "なまえ", "romaji": "namae", "translation": "name", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "tags": ["basics"], "examples": [{ "text": "お名前は何ですか？", "reading": "おなまえはなんですか？", "romaji": "Onamae wa nan desu ka?", "translation": "What is your name?" }] },
  { "schemaVersion": 1, "key": "vocab.ichi", "entryType": "word", "lemma": "一", "reading": "いち", "romaji": "ichi", "translation": "one", "partOfSpeech": "numeral", "cefr": "A1", "register": "neutral", "tags": ["numbers"] },
  { "schemaVersion": 1, "key": "vocab.ni", "entryType": "word", "lemma": "二", "reading": "に", "romaji": "ni", "translation": "two", "partOfSpeech": "numeral", "cefr": "A1", "register": "neutral", "tags": ["numbers"] },
  { "schemaVersion": 1, "key": "vocab.san", "entryType": "word", "lemma": "三", "reading": "さん", "romaji": "san", "translation": "three", "partOfSpeech": "numeral", "cefr": "A1", "register": "neutral", "tags": ["numbers"] },
  { "schemaVersion": 1, "key": "vocab.yon", "entryType": "word", "lemma": "四", "reading": "よん", "romaji": "yon", "translation": "four", "partOfSpeech": "numeral", "cefr": "A1", "register": "neutral", "tags": ["numbers"], "naturalMeaning": "Also read し (shi) — but し sounds like the word for 'death', so よん is preferred in most everyday contexts." },
  { "schemaVersion": 1, "key": "vocab.go-number", "entryType": "word", "lemma": "五", "reading": "ご", "romaji": "go", "translation": "five", "partOfSpeech": "numeral", "cefr": "A1", "register": "neutral", "tags": ["numbers"] },
  { "schemaVersion": 1, "key": "vocab.roku", "entryType": "word", "lemma": "六", "reading": "ろく", "romaji": "roku", "translation": "six", "partOfSpeech": "numeral", "cefr": "A1", "register": "neutral", "tags": ["numbers"] },
  { "schemaVersion": 1, "key": "vocab.nana", "entryType": "word", "lemma": "七", "reading": "なな", "romaji": "nana", "translation": "seven", "partOfSpeech": "numeral", "cefr": "A1", "register": "neutral", "tags": ["numbers"], "naturalMeaning": "Also read しち (shichi) — なな is preferred in speech since しち can be misheard as いち (one)." },
  { "schemaVersion": 1, "key": "vocab.hachi", "entryType": "word", "lemma": "八", "reading": "はち", "romaji": "hachi", "translation": "eight", "partOfSpeech": "numeral", "cefr": "A1", "register": "neutral", "tags": ["numbers"] },
  { "schemaVersion": 1, "key": "vocab.kyuu", "entryType": "word", "lemma": "九", "reading": "きゅう", "romaji": "kyuu", "translation": "nine", "partOfSpeech": "numeral", "cefr": "A1", "register": "neutral", "tags": ["numbers"], "naturalMeaning": "Also read く (ku) — く sounds like 'suffering', so きゅう is the everyday choice." },
  { "schemaVersion": 1, "key": "vocab.juu", "entryType": "word", "lemma": "十", "reading": "じゅう", "romaji": "juu", "translation": "ten", "partOfSpeech": "numeral", "cefr": "A1", "register": "neutral", "tags": ["numbers"] },
  { "schemaVersion": 1, "key": "vocab.kyou", "entryType": "word", "lemma": "今日", "reading": "きょう", "romaji": "kyou", "translation": "today", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "tags": ["time"], "examples": [{ "text": "今日は暑いですね。", "reading": "きょうはあついですね。", "romaji": "Kyou wa atsui desu ne.", "translation": "It's hot today, isn't it." }] },
  { "schemaVersion": 1, "key": "vocab.ashita", "entryType": "word", "lemma": "明日", "reading": "あした", "romaji": "ashita", "translation": "tomorrow", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "tags": ["time"] },
  { "schemaVersion": 1, "key": "vocab.kinou", "entryType": "word", "lemma": "昨日", "reading": "きのう", "romaji": "kinou", "translation": "yesterday", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "tags": ["time"] },
  { "schemaVersion": 1, "key": "vocab.ima", "entryType": "word", "lemma": "今", "reading": "いま", "romaji": "ima", "translation": "now", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "tags": ["time"], "examples": [{ "text": "今、忙しいです。", "reading": "いま、いそがしいです。", "romaji": "Ima, isogashii desu.", "translation": "I'm busy right now." }] },
  { "schemaVersion": 1, "key": "vocab.asa", "entryType": "word", "lemma": "朝", "reading": "あさ", "romaji": "asa", "translation": "morning", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "tags": ["time"] },
  { "schemaVersion": 1, "key": "vocab.yoru", "entryType": "word", "lemma": "夜", "reading": "よる", "romaji": "yoru", "translation": "night", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "tags": ["time"] },
  { "schemaVersion": 1, "key": "vocab.konshuu", "entryType": "word", "lemma": "今週", "reading": "こんしゅう", "romaji": "konshuu", "translation": "this week", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "tags": ["time"] },
  { "schemaVersion": 1, "key": "vocab.kazoku", "entryType": "word", "lemma": "家族", "reading": "かぞく", "romaji": "kazoku", "translation": "family", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "tags": ["family"] },
  { "schemaVersion": 1, "key": "vocab.haha", "entryType": "word", "lemma": "母", "reading": "はは", "romaji": "haha", "translation": "(my) mother", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "tags": ["family"], "naturalMeaning": "母 is only for talking about your own mother; someone else's mother is お母さん (okaasan), which is also how you address your own mother directly." },
  { "schemaVersion": 1, "key": "vocab.chichi", "entryType": "word", "lemma": "父", "reading": "ちち", "romaji": "chichi", "translation": "(my) father", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "tags": ["family"], "naturalMeaning": "Same pattern as 母/お母さん: 父 for your own father in conversation with others, お父さん (otousan) to address him or refer to someone else's father." },
  { "schemaVersion": 1, "key": "vocab.tomodachi", "entryType": "word", "lemma": "友達", "reading": "ともだち", "romaji": "tomodachi", "translation": "friend", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "tags": ["family", "people"], "examples": [{ "text": "彼は私の友達です。", "reading": "かれはわたしのともだちです。", "romaji": "Kare wa watashi no tomodachi desu.", "translation": "He is my friend." }] },
  { "schemaVersion": 1, "key": "vocab.mizu", "entryType": "word", "lemma": "水", "reading": "みず", "romaji": "mizu", "translation": "water", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "tags": ["food-drink"] },
  { "schemaVersion": 1, "key": "vocab.ocha", "entryType": "word", "lemma": "お茶", "reading": "おちゃ", "romaji": "ocha", "translation": "tea", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "tags": ["food-drink"] },
  { "schemaVersion": 1, "key": "vocab.gohan", "entryType": "word", "lemma": "ご飯", "reading": "ごはん", "romaji": "gohan", "translation": "rice / a meal", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "tags": ["food-drink"], "naturalMeaning": "ご飯 means both 'cooked rice' specifically and 'meal' generally — 朝ご飯 (asagohan) is literally 'morning rice' but just means breakfast." },
  { "schemaVersion": 1, "key": "vocab.tabemono", "entryType": "word", "lemma": "食べ物", "reading": "たべもの", "romaji": "tabemono", "translation": "food", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "tags": ["food-drink"] },
  { "schemaVersion": 1, "key": "vocab.taberu", "entryType": "word", "lemma": "食べる", "reading": "たべる", "romaji": "taberu", "translation": "to eat", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb"], "examples": [{ "text": "朝ご飯を食べます。", "reading": "あさごはんをたべます。", "romaji": "Asagohan o tabemasu.", "translation": "I eat breakfast." }] },
  { "schemaVersion": 1, "key": "vocab.nomu", "entryType": "word", "lemma": "飲む", "reading": "のむ", "romaji": "nomu", "translation": "to drink", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb"], "examples": [{ "text": "水を飲みます。", "reading": "みずをのみます。", "romaji": "Mizu o nomimasu.", "translation": "I drink water." }] },
  { "schemaVersion": 1, "key": "vocab.hanasu", "entryType": "word", "lemma": "話す", "reading": "はなす", "romaji": "hanasu", "translation": "to speak", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb"], "examples": [{ "text": "日本語を話します。", "reading": "にほんごをはなします。", "romaji": "Nihongo o hanashimasu.", "translation": "I speak Japanese." }] },
  { "schemaVersion": 1, "key": "vocab.miru", "entryType": "word", "lemma": "見る", "reading": "みる", "romaji": "miru", "translation": "to see / to watch", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb"] },
  { "schemaVersion": 1, "key": "vocab.iku", "entryType": "word", "lemma": "行く", "reading": "いく", "romaji": "iku", "translation": "to go", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb"], "examples": [{ "text": "学校に行きます。", "reading": "がっこうにいきます。", "romaji": "Gakkou ni ikimasu.", "translation": "I go to school." }] },
  { "schemaVersion": 1, "key": "vocab.kuru", "entryType": "word", "lemma": "来る", "reading": "くる", "romaji": "kuru", "translation": "to come", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb"], "pronunciationNotes": "Irregular verb — the kanji reading changes across conjugations (来ます kimasu, 来ない konai)." },
  { "schemaVersion": 1, "key": "vocab.suru", "entryType": "word", "lemma": "する", "romaji": "suru", "translation": "to do", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb"], "naturalMeaning": "Combines with huge numbers of nouns to make verbs: 勉強する (benkyou suru, to study), 電話する (denwa suru, to phone)." },
  { "schemaVersion": 1, "key": "vocab.aru", "entryType": "word", "lemma": "ある", "romaji": "aru", "translation": "to exist / to have (inanimate)", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb"], "naturalMeaning": "For inanimate things and abstract things (books, time, plans). Living things use いる instead — this animate/inanimate split has no English equivalent." },
  { "schemaVersion": 1, "key": "vocab.iru", "entryType": "word", "lemma": "いる", "romaji": "iru", "translation": "to exist / to have (animate)", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb"], "examples": [{ "text": "猫が家にいます。", "reading": "ねこがいえにいます。", "romaji": "Neko ga ie ni imasu.", "translation": "There's a cat at home." }] },
  { "schemaVersion": 1, "key": "vocab.wakaru", "entryType": "word", "lemma": "わかる", "romaji": "wakaru", "translation": "to understand", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb"], "examples": [{ "text": "わかりました。", "romaji": "Wakarimashita.", "translation": "I understand. / Got it." }] },
  { "schemaVersion": 1, "key": "vocab.ookii", "entryType": "word", "lemma": "大きい", "reading": "おおきい", "romaji": "ookii", "translation": "big", "partOfSpeech": "adjective", "cefr": "A1", "register": "neutral", "tags": ["adjective"] },
  { "schemaVersion": 1, "key": "vocab.chiisai", "entryType": "word", "lemma": "小さい", "reading": "ちいさい", "romaji": "chiisai", "translation": "small", "partOfSpeech": "adjective", "cefr": "A1", "register": "neutral", "tags": ["adjective"] },
  { "schemaVersion": 1, "key": "vocab.ii", "entryType": "word", "lemma": "いい", "romaji": "ii", "translation": "good", "partOfSpeech": "adjective", "cefr": "A1", "register": "neutral", "tags": ["adjective"], "naturalMeaning": "Written 良い (yoi) in dictionaries, but said いい in everyday speech — one of the few adjectives where the casual reading fully replaces the 'proper' one." },
  { "schemaVersion": 1, "key": "vocab.oishii", "entryType": "word", "lemma": "おいしい", "romaji": "oishii", "translation": "delicious", "partOfSpeech": "adjective", "cefr": "A1", "register": "neutral", "tags": ["adjective", "food-drink"], "examples": [{ "text": "これ、おいしいですね！", "romaji": "Kore, oishii desu ne!", "translation": "This is delicious!" }] },
  { "schemaVersion": 1, "key": "vocab.tanoshii", "entryType": "word", "lemma": "楽しい", "reading": "たのしい", "romaji": "tanoshii", "translation": "fun / enjoyable", "partOfSpeech": "adjective", "cefr": "A1", "register": "neutral", "tags": ["adjective"] },
  { "schemaVersion": 1, "key": "vocab.suki", "entryType": "word", "lemma": "好き", "reading": "すき", "romaji": "suki", "translation": "likeable / to like", "partOfSpeech": "adjective", "cefr": "A1", "register": "neutral", "tags": ["adjective"], "naturalMeaning": "Grammatically an adjective describing the thing liked, not a verb you 'do' — 私は寿司が好きです literally reads closer to 'as for me, sushi is likeable'." },
  { "schemaVersion": 1, "key": "vocab.gakkou", "entryType": "word", "lemma": "学校", "reading": "がっこう", "romaji": "gakkou", "translation": "school", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "tags": ["places"] },
  { "schemaVersion": 1, "key": "vocab.ie", "entryType": "word", "lemma": "家", "reading": "いえ", "romaji": "ie", "translation": "house / home", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "tags": ["places"] },
  { "schemaVersion": 1, "key": "vocab.eki", "entryType": "word", "lemma": "駅", "reading": "えき", "romaji": "eki", "translation": "station", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "tags": ["places"] },
  { "schemaVersion": 1, "key": "vocab.mise", "entryType": "word", "lemma": "店", "reading": "みせ", "romaji": "mise", "translation": "shop / store", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "tags": ["places"] },
  { "schemaVersion": 1, "key": "vocab.nani", "entryType": "word", "lemma": "何", "reading": "なに", "romaji": "nani", "translation": "what", "partOfSpeech": "pronoun", "cefr": "A1", "register": "neutral", "tags": ["basics", "questions"], "naturalMeaning": "Read なん (nan) before で/の and some other sounds: 何ですか (nan desu ka), but なにか (nanika, 'something')." },
  { "schemaVersion": 1, "key": "vocab.doko", "entryType": "word", "lemma": "どこ", "romaji": "doko", "translation": "where", "partOfSpeech": "pronoun", "cefr": "A1", "register": "neutral", "tags": ["basics", "questions"] },
  { "schemaVersion": 1, "key": "vocab.dare", "entryType": "word", "lemma": "誰", "reading": "だれ", "romaji": "dare", "translation": "who", "partOfSpeech": "pronoun", "cefr": "A1", "register": "neutral", "tags": ["basics", "questions"] }
]
