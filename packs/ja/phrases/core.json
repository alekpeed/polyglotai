[
  { "schemaVersion": 1, "key": "phrase.hajimemashite", "entryType": "phrase", "lemma": "はじめまして", "romaji": "hajimemashite", "translation": "nice to meet you (first time)", "cefr": "A1", "register": "formal", "tags": ["greeting"], "naturalMeaning": "Said only at a genuine first meeting — literally 'for the first time'. Usually followed immediately by よろしくお願いします." },
  { "schemaVersion": 1, "key": "phrase.yoroshiku-onegaishimasu", "entryType": "phrase", "lemma": "よろしくお願いします", "reading": "よろしくおねがいします", "romaji": "yoroshiku onegaishimasu", "translation": "please treat me well / I look forward to it", "cefr": "A1", "register": "formal", "tags": ["greeting", "courtesy"], "naturalMeaning": "Almost untranslatable — a social lubricant said at introductions, when asking a favor, or starting to work with someone. Closes countless emails too." },
  { "schemaVersion": 1, "key": "phrase.ogenki-desuka", "entryType": "phrase", "lemma": "お元気ですか", "reading": "おげんきですか", "romaji": "ogenki desu ka", "translation": "how are you?", "cefr": "A1", "register": "formal", "tags": ["greeting"], "naturalMeaning": "Not a daily greeting like English 'how are you' — it implies you haven't seen someone for a while. Asking it every day sounds odd." },
  { "schemaVersion": 1, "key": "phrase.okagesama-de", "entryType": "phrase", "lemma": "おかげさまで", "romaji": "okagesama de", "translation": "thanks to you (I'm well)", "cefr": "A2", "register": "formal", "tags": ["courtesy"], "naturalMeaning": "The gracious standard reply to お元気ですか — a humble 'I'm doing well, thanks to you/others', even when the listener did nothing specific." },
  { "schemaVersion": 1, "key": "phrase.ohisashiburi", "entryType": "phrase", "lemma": "お久しぶりです", "reading": "おひさしぶりです", "romaji": "ohisashiburi desu", "translation": "long time no see", "cefr": "A2", "register": "neutral", "tags": ["greeting"], "naturalMeaning": "Casual form is 久しぶり (hisashiburi) with friends. Reunion opener, roughly 'it's been a while'." },
  { "schemaVersion": 1, "key": "phrase.tadaima", "entryType": "phrase", "lemma": "ただいま", "romaji": "tadaima", "translation": "I'm home / I'm back", "cefr": "A1", "register": "informal", "tags": ["greeting", "home"], "naturalMeaning": "Announced on returning home; the person there replies おかえりなさい. A fixed ritual pair in Japanese households." },
  { "schemaVersion": 1, "key": "phrase.okaerinasai", "entryType": "phrase", "lemma": "おかえりなさい", "romaji": "okaerinasai", "translation": "welcome back", "cefr": "A1", "register": "neutral", "tags": ["greeting", "home"], "naturalMeaning": "The reply to ただいま. Shortened to おかえり among family and close friends." },
  { "schemaVersion": 1, "key": "phrase.ittekimasu", "entryType": "phrase", "lemma": "いってきます", "romaji": "ittekimasu", "translation": "I'm off (and coming back)", "cefr": "A1", "register": "informal", "tags": ["greeting", "home"], "naturalMeaning": "Said when leaving home; literally 'I'll go and come back'. The person staying replies いってらっしゃい." },
  { "schemaVersion": 1, "key": "phrase.itterasshai", "entryType": "phrase", "lemma": "いってらっしゃい", "romaji": "itterasshai", "translation": "see you (go and come back safely)", "cefr": "A1", "register": "neutral", "tags": ["greeting", "home"], "naturalMeaning": "The send-off reply to いってきます." },
  { "schemaVersion": 1, "key": "phrase.oyasuminasai", "entryType": "phrase", "lemma": "おやすみなさい", "romaji": "oyasuminasai", "translation": "good night", "cefr": "A1", "register": "neutral", "tags": ["greeting"], "naturalMeaning": "Casual form おやすみ with friends and family. Said before sleeping or parting late at night." },
  { "schemaVersion": 1, "key": "phrase.itadakimasu", "entryType": "phrase", "lemma": "いただきます", "romaji": "itadakimasu", "translation": "(said before eating)", "cefr": "A1", "register": "neutral", "tags": ["food-drink", "ritual"], "naturalMeaning": "A humble 'I gratefully receive', said before every meal — gratitude for the food and everyone who made it possible. No real English equivalent." },
  { "schemaVersion": 1, "key": "phrase.gochisousama", "entryType": "phrase", "lemma": "ごちそうさまでした", "romaji": "gochisousama deshita", "translation": "thank you for the meal (after eating)", "cefr": "A1", "register": "neutral", "tags": ["food-drink", "ritual"], "naturalMeaning": "Said after finishing a meal, and to whoever cooked or paid. The bookend to いただきます." },
  { "schemaVersion": 1, "key": "phrase.otsukaresama", "entryType": "phrase", "lemma": "お疲れ様です", "reading": "おつかれさまです", "romaji": "otsukaresama desu", "translation": "thanks for your hard work / hi (at work)", "cefr": "A2", "register": "formal", "tags": ["work"], "naturalMeaning": "The all-purpose workplace phrase — a greeting, an acknowledgment, and a goodbye. Past form お疲れ様でした when leaving for the day." },
  { "schemaVersion": 1, "key": "phrase.omedetou-gozaimasu", "entryType": "phrase", "lemma": "おめでとうございます", "romaji": "omedetou gozaimasu", "translation": "congratulations", "cefr": "A1", "register": "formal", "tags": ["courtesy"], "naturalMeaning": "Drop ございます for the casual おめでとう. Used for birthdays, weddings, New Year (明けましておめでとう), any celebration." },
  { "schemaVersion": 1, "key": "phrase.odaijini", "entryType": "phrase", "lemma": "お大事に", "reading": "おだいじに", "romaji": "odaiji ni", "translation": "take care (get well soon)", "cefr": "A2", "register": "neutral", "tags": ["courtesy", "health"], "naturalMeaning": "Said to someone who's sick or hurt — what a doctor or pharmacist says as you leave. Not a general 'take care'." },
  { "schemaVersion": 1, "key": "phrase.kiotsukete", "entryType": "phrase", "lemma": "気をつけて", "reading": "きをつけて", "romaji": "ki o tsukete", "translation": "take care / be careful", "cefr": "A2", "register": "neutral", "tags": ["courtesy"], "naturalMeaning": "The 'take care' you say to someone heading out or traveling — 'be safe'. Distinct from お大事に (for illness)." },
  { "schemaVersion": 1, "key": "phrase.douitashimashite", "entryType": "phrase", "lemma": "どういたしまして", "romaji": "dou itashimashite", "translation": "you're welcome", "cefr": "A1", "register": "neutral", "tags": ["courtesy"], "naturalMeaning": "Textbook 'you're welcome', but in casual life people more often wave off thanks with いえいえ or 大丈夫." },
  { "schemaVersion": 1, "key": "phrase.gomennasai", "entryType": "phrase", "lemma": "ごめんなさい", "romaji": "gomen nasai", "translation": "I'm sorry", "cefr": "A1", "register": "neutral", "tags": ["courtesy"], "naturalMeaning": "A sincere, personal apology. Casual form ごめん. For lighter 'excuse me' or formal apologies, すみません fits better." },
  { "schemaVersion": 1, "key": "phrase.shitsurei-shimasu", "entryType": "phrase", "lemma": "失礼します", "reading": "しつれいします", "romaji": "shitsurei shimasu", "translation": "excuse me (entering/leaving)", "cefr": "A2", "register": "formal", "tags": ["courtesy", "work"], "naturalMeaning": "Literally 'I'm being rude' — said entering a room, leaving before others, or ending a call. Past form 失礼しました also apologizes for a small lapse." },
  { "schemaVersion": 1, "key": "phrase.onegaishimasu", "entryType": "phrase", "lemma": "お願いします", "reading": "おねがいします", "romaji": "onegaishimasu", "translation": "please (I request)", "cefr": "A1", "register": "formal", "tags": ["courtesy"], "naturalMeaning": "The polite way to request a thing or a service — put a noun in front: お水をお願いします ('water, please')." },
  { "schemaVersion": 1, "key": "phrase.kekkou-desu", "entryType": "phrase", "lemma": "結構です", "reading": "けっこうです", "romaji": "kekkou desu", "translation": "no thank you / that's fine", "cefr": "A2", "register": "formal", "tags": ["courtesy"], "naturalMeaning": "A polite refusal ('I'm good, thanks') but also 'that's fine' — tone and context decide. Can sound curt if too flat; often softened with いえ、結構です." },
  { "schemaVersion": 1, "key": "phrase.daijoubu-desu", "entryType": "phrase", "lemma": "大丈夫です", "reading": "だいじょうぶです", "romaji": "daijoubu desu", "translation": "it's fine / I'm okay / no thanks", "cefr": "A1", "register": "neutral", "tags": ["courtesy"], "naturalMeaning": "Wildly versatile — 'I'm okay', 'no problem', and a soft 'no thanks' when declining an offer. Context and intonation carry the meaning." },
  { "schemaVersion": 1, "key": "phrase.kashikomarimashita", "entryType": "phrase", "lemma": "かしこまりました", "romaji": "kashikomarimashita", "translation": "certainly / understood (very polite)", "cefr": "A2", "register": "formal", "tags": ["work", "service"], "naturalMeaning": "Keigo you'll hear from staff — a deferential 'understood'. You'd say わかりました in ordinary polite speech." },
  { "schemaVersion": 1, "key": "phrase.shoushou-omachi", "entryType": "phrase", "lemma": "少々お待ちください", "reading": "しょうしょうおまちください", "romaji": "shoushou omachi kudasai", "translation": "please wait a moment", "cefr": "A2", "register": "formal", "tags": ["service"], "naturalMeaning": "Polite service phrase. Among peers you'd say ちょっと待ってください or casually ちょっと待って." },
  { "schemaVersion": 1, "key": "phrase.mou-ichido", "entryType": "phrase", "lemma": "もう一度お願いします", "reading": "もういちどおねがいします", "romaji": "mou ichido onegaishimasu", "translation": "one more time, please", "cefr": "A1", "register": "neutral", "tags": ["communication"], "naturalMeaning": "The go-to when you didn't catch something — 'could you repeat that?'." },
  { "schemaVersion": 1, "key": "phrase.yukkuri-onegai", "entryType": "phrase", "lemma": "ゆっくり話してください", "reading": "ゆっくりはなしてください", "romaji": "yukkuri hanashite kudasai", "translation": "please speak slowly", "cefr": "A1", "register": "neutral", "tags": ["communication"], "naturalMeaning": "Essential learner phrase — 'please speak slowly'." },
  { "schemaVersion": 1, "key": "phrase.wakarimasen", "entryType": "phrase", "lemma": "わかりません", "romaji": "wakarimasen", "translation": "I don't understand", "cefr": "A1", "register": "neutral", "tags": ["communication"], "naturalMeaning": "'I don't understand / I don't know (the answer)'. Soften with ちょっとわかりません to sound less blunt." },
  { "schemaVersion": 1, "key": "phrase.nihongo-sukoshi", "entryType": "phrase", "lemma": "日本語が少し話せます", "reading": "にほんごがすこしはなせます", "romaji": "nihongo ga sukoshi hanasemasu", "translation": "I can speak a little Japanese", "cefr": "A2", "register": "neutral", "tags": ["communication", "language"] },
  { "schemaVersion": 1, "key": "phrase.eigo-hanasemasuka", "entryType": "phrase", "lemma": "英語を話せますか", "reading": "えいごをはなせますか", "romaji": "eigo o hanasemasu ka", "translation": "can you speak English?", "cefr": "A2", "register": "neutral", "tags": ["communication", "language"] },
  { "schemaVersion": 1, "key": "phrase.nihongo-de-nanto", "entryType": "phrase", "lemma": "日本語で何と言いますか", "reading": "にほんごでなんといいますか", "romaji": "nihongo de nan to iimasu ka", "translation": "how do you say it in Japanese?", "cefr": "A2", "register": "neutral", "tags": ["communication", "language"], "naturalMeaning": "The single most useful learner question — point at something and ask what it's called." },
  { "schemaVersion": 1, "key": "phrase.douiu-imi", "entryType": "phrase", "lemma": "どういう意味ですか", "reading": "どういういみですか", "romaji": "dou iu imi desu ka", "translation": "what does it mean?", "cefr": "A2", "register": "neutral", "tags": ["communication", "language"] },
  { "schemaVersion": 1, "key": "phrase.kaite-kudasai", "entryType": "phrase", "lemma": "書いてください", "reading": "かいてください", "romaji": "kaite kudasai", "translation": "please write it (down)", "cefr": "A1", "register": "neutral", "tags": ["communication"], "naturalMeaning": "Handy when you can't catch a name or number spoken aloud." },
  { "schemaVersion": 1, "key": "phrase.kore-wa-nan", "entryType": "phrase", "lemma": "これは何ですか", "reading": "これはなんですか", "romaji": "kore wa nan desu ka", "translation": "what is this?", "cefr": "A1", "register": "neutral", "tags": ["basics", "questions"] },
  { "schemaVersion": 1, "key": "phrase.ikura-desuka", "entryType": "phrase", "lemma": "いくらですか", "romaji": "ikura desu ka", "translation": "how much is it?", "cefr": "A1", "register": "neutral", "tags": ["shopping", "money"] },
  { "schemaVersion": 1, "key": "phrase.kore-o-kudasai", "entryType": "phrase", "lemma": "これをください", "romaji": "kore o kudasai", "translation": "this one, please (I'll take this)", "cefr": "A1", "register": "neutral", "tags": ["shopping"], "naturalMeaning": "Point and say it — the standard way to buy or order a specific item. ください requests a thing; お願いします works too." },
  { "schemaVersion": 1, "key": "phrase.menu-onegai", "entryType": "phrase", "lemma": "メニューをお願いします", "romaji": "menyuu o onegaishimasu", "translation": "the menu, please", "cefr": "A1", "register": "neutral", "tags": ["restaurant"] },
  { "schemaVersion": 1, "key": "phrase.okaikei-onegai", "entryType": "phrase", "lemma": "お会計をお願いします", "reading": "おかいけいをおねがいします", "romaji": "okaikei o onegaishimasu", "translation": "the check, please", "cefr": "A2", "register": "neutral", "tags": ["restaurant", "money"], "naturalMeaning": "お会計 or お勘定 (okanjou) both work. Many restaurants have you pay at the register up front rather than at the table." },
  { "schemaVersion": 1, "key": "phrase.osusume-wa-nan", "entryType": "phrase", "lemma": "おすすめは何ですか", "reading": "おすすめはなんですか", "romaji": "osusume wa nan desu ka", "translation": "what do you recommend?", "cefr": "A2", "register": "neutral", "tags": ["restaurant", "shopping"] },
  { "schemaVersion": 1, "key": "phrase.toire-wa-doko", "entryType": "phrase", "lemma": "トイレはどこですか", "romaji": "toire wa doko desu ka", "translation": "where is the toilet?", "cefr": "A1", "register": "neutral", "tags": ["travel", "questions"], "naturalMeaning": "In polite settings, お手洗いはどこですか sounds a touch more refined." },
  { "schemaVersion": 1, "key": "phrase.eki-made-dou", "entryType": "phrase", "lemma": "駅までどうやって行きますか", "reading": "えきまでどうやっていきますか", "romaji": "eki made dou yatte ikimasu ka", "translation": "how do I get to the station?", "cefr": "A2", "register": "neutral", "tags": ["travel", "directions"] },
  { "schemaVersion": 1, "key": "phrase.chikaku-ni-konbini", "entryType": "phrase", "lemma": "近くにコンビニはありますか", "reading": "ちかくにコンビニはありますか", "romaji": "chikaku ni konbini wa arimasu ka", "translation": "is there a convenience store nearby?", "cefr": "A2", "register": "neutral", "tags": ["travel", "directions"] },
  { "schemaVersion": 1, "key": "phrase.yoyaku-onegai", "entryType": "phrase", "lemma": "予約をお願いします", "reading": "よやくをおねがいします", "romaji": "yoyaku o onegaishimasu", "translation": "I'd like to make a reservation", "cefr": "A2", "register": "formal", "tags": ["travel", "restaurant"] },
  { "schemaVersion": 1, "key": "phrase.shashin-ii", "entryType": "phrase", "lemma": "写真を撮ってもいいですか", "reading": "しゃしんをとってもいいですか", "romaji": "shashin o totte mo ii desu ka", "translation": "may I take a photo?", "cefr": "A2", "register": "neutral", "tags": ["travel"], "naturalMeaning": "Uses the ～てもいいですか 'is it okay to...' permission pattern — polite and important at temples, shops, and around people." },
  { "schemaVersion": 1, "key": "phrase.tetsudatte-kudasai", "entryType": "phrase", "lemma": "手伝ってください", "reading": "てつだってください", "romaji": "tetsudatte kudasai", "translation": "please help me", "cefr": "A2", "register": "neutral", "tags": ["courtesy"] },
  { "schemaVersion": 1, "key": "phrase.michi-ni-mayoimashita", "entryType": "phrase", "lemma": "道に迷いました", "reading": "みちにまよいました", "romaji": "michi ni mayoimashita", "translation": "I'm lost", "cefr": "A2", "register": "neutral", "tags": ["travel", "directions"], "naturalMeaning": "Literally 'I got lost on the road' — the natural way to say you can't find your way." },
  { "schemaVersion": 1, "key": "phrase.tasukete", "entryType": "phrase", "lemma": "助けてください", "reading": "たすけてください", "romaji": "tasukete kudasai", "translation": "please help! (emergency)", "cefr": "A2", "register": "neutral", "tags": ["emergency"], "naturalMeaning": "For real trouble/danger — 助けて! shouted alone is a cry for help. Everyday 'give me a hand' is 手伝って, not 助けて." },
  { "schemaVersion": 1, "key": "phrase.card-de-haraemasu", "entryType": "phrase", "lemma": "カードで払えますか", "reading": "カードではらえますか", "romaji": "kaado de haraemasu ka", "translation": "can I pay by card?", "cefr": "A2", "register": "neutral", "tags": ["shopping", "money"], "naturalMeaning": "Worth asking — Japan is still more cash-based than many countries, especially at small shops." },
  { "schemaVersion": 1, "key": "phrase.mochikaeri", "entryType": "phrase", "lemma": "持ち帰りできますか", "reading": "もちかえりできますか", "romaji": "mochikaeri dekimasu ka", "translation": "can I take it to go?", "cefr": "A2", "register": "neutral", "tags": ["restaurant"], "naturalMeaning": "持ち帰り is 'takeout'. Staff may ask 店内でお召し上がりですか (eat in?) or お持ち帰りですか (takeout?)." },
  { "schemaVersion": 1, "key": "phrase.eigo-menu", "entryType": "phrase", "lemma": "英語のメニューはありますか", "reading": "えいごのメニューはありますか", "romaji": "eigo no menyuu wa arimasu ka", "translation": "do you have an English menu?", "cefr": "A2", "register": "neutral", "tags": ["restaurant", "travel"] },
  { "schemaVersion": 1, "key": "phrase.shusshin-wa-doko", "entryType": "phrase", "lemma": "出身はどこですか", "reading": "しゅっしんはどこですか", "romaji": "shusshin wa doko desu ka", "translation": "where are you from?", "cefr": "A2", "register": "neutral", "tags": ["small-talk"], "naturalMeaning": "出身 is where you're originally from (hometown/country) — different from where you live now (どこに住んでいますか)." },
  { "schemaVersion": 1, "key": "phrase.doko-ni-sundeimasuka", "entryType": "phrase", "lemma": "どこに住んでいますか", "reading": "どこにすんでいますか", "romaji": "doko ni sunde imasu ka", "translation": "where do you live?", "cefr": "A2", "register": "neutral", "tags": ["small-talk"], "naturalMeaning": "Uses 住んでいる ('am living') — living somewhere is a continuous state, so it takes the ～ている form, not plain 住む." },
  { "schemaVersion": 1, "key": "phrase.nihon-hajimete", "entryType": "phrase", "lemma": "日本は初めてです", "reading": "にほんははじめてです", "romaji": "nihon wa hajimete desu", "translation": "it's my first time in Japan", "cefr": "A2", "register": "neutral", "tags": ["small-talk", "travel"] },
  { "schemaVersion": 1, "key": "phrase.shigoto-wa-nan", "entryType": "phrase", "lemma": "お仕事は何ですか", "reading": "おしごとはなんですか", "romaji": "oshigoto wa nan desu ka", "translation": "what do you do (for work)?", "cefr": "A2", "register": "formal", "tags": ["small-talk", "work"], "naturalMeaning": "The polite お- on 仕事 is standard when asking about someone else's job." },
  { "schemaVersion": 1, "key": "phrase.shumi-wa-nan", "entryType": "phrase", "lemma": "趣味は何ですか", "reading": "しゅみはなんですか", "romaji": "shumi wa nan desu ka", "translation": "what are your hobbies?", "cefr": "A2", "register": "neutral", "tags": ["small-talk"] },
  { "schemaVersion": 1, "key": "phrase.mata-aimashou", "entryType": "phrase", "lemma": "また会いましょう", "reading": "またあいましょう", "romaji": "mata aimashou", "translation": "let's meet again", "cefr": "A2", "register": "neutral", "tags": ["greeting"], "naturalMeaning": "Warm parting between people who want to stay in touch — uses the ～ましょう 'let's' form." },
  { "schemaVersion": 1, "key": "phrase.tanoshikatta", "entryType": "phrase", "lemma": "楽しかったです", "reading": "たのしかったです", "romaji": "tanoshikatta desu", "translation": "it was fun", "cefr": "A1", "register": "neutral", "tags": ["small-talk", "feelings"], "naturalMeaning": "Note the past of the い-adjective: 楽しい → 楽しかった, then plain です (not でした)." },
  { "schemaVersion": 1, "key": "phrase.sou-desu-ne", "entryType": "phrase", "lemma": "そうですね", "romaji": "sou desu ne", "translation": "that's right / let me see", "cefr": "A1", "register": "neutral", "tags": ["conversation"], "naturalMeaning": "A conversational workhorse: agreement ('yeah, true'), or a thinking-pause before answering. The ね invites the listener to share the feeling." },
  { "schemaVersion": 1, "key": "phrase.sou-desu-ka", "entryType": "phrase", "lemma": "そうですか", "romaji": "sou desu ka", "translation": "is that so? / I see", "cefr": "A1", "register": "neutral", "tags": ["conversation"], "naturalMeaning": "Acknowledges new information. Falling intonation = 'I see'; rising = genuine mild surprise, 'oh really?'." },
  { "schemaVersion": 1, "key": "phrase.hontou-desuka", "entryType": "phrase", "lemma": "本当ですか", "reading": "ほんとうですか", "romaji": "hontou desu ka", "translation": "really?", "cefr": "A1", "register": "neutral", "tags": ["conversation"], "naturalMeaning": "Casual clipped form 本当？ (hontou?) or ほんと？ shows surprise among friends." },
  { "schemaVersion": 1, "key": "phrase.naruhodo", "entryType": "phrase", "lemma": "なるほど", "romaji": "naruhodo", "translation": "I see / that makes sense", "cefr": "A2", "register": "neutral", "tags": ["conversation"], "naturalMeaning": "Signals a genuine 'ah, now I get it'. Overusing it upward (to a boss/teacher) can sound slightly presumptuous." },
  { "schemaVersion": 1, "key": "phrase.ii-desu-ne", "entryType": "phrase", "lemma": "いいですね", "romaji": "ii desu ne", "translation": "that's nice / sounds good", "cefr": "A1", "register": "neutral", "tags": ["conversation", "feelings"], "naturalMeaning": "Warm agreement or approval of an idea or plan — 'nice!' / 'sounds good!'." },
  { "schemaVersion": 1, "key": "phrase.zannen-desu-ne", "entryType": "phrase", "lemma": "残念ですね", "reading": "ざんねんですね", "romaji": "zannen desu ne", "translation": "that's too bad", "cefr": "A2", "register": "neutral", "tags": ["conversation", "feelings"], "naturalMeaning": "Standard sympathetic response to disappointing news — 'what a shame'." },
  { "schemaVersion": 1, "key": "phrase.yokatta", "entryType": "phrase", "lemma": "よかったです", "romaji": "yokatta desu", "translation": "that's good / I'm glad", "cefr": "A1", "register": "neutral", "tags": ["conversation", "feelings"], "naturalMeaning": "Past of いい → よかった: relief or gladness that something worked out. Plain よかった alone is a heartfelt 'oh good / thank goodness'." },
  { "schemaVersion": 1, "key": "phrase.tanoshimi", "entryType": "phrase", "lemma": "楽しみです", "reading": "たのしみです", "romaji": "tanoshimi desu", "translation": "I'm looking forward to it", "cefr": "A2", "register": "neutral", "tags": ["feelings"], "naturalMeaning": "Anticipation of something ahead. 楽しみにしています is a slightly fuller, warmer version." },
  { "schemaVersion": 1, "key": "phrase.daijoubu-desuka", "entryType": "phrase", "lemma": "大丈夫ですか", "reading": "だいじょうぶですか", "romaji": "daijoubu desu ka", "translation": "are you okay?", "cefr": "A1", "register": "neutral", "tags": ["conversation", "courtesy"], "naturalMeaning": "Checks on someone who seems unwell, upset, or in trouble — 'you all right?'." },
  { "schemaVersion": 1, "key": "phrase.ima-nanji", "entryType": "phrase", "lemma": "今何時ですか", "reading": "いまなんじですか", "romaji": "ima nanji desu ka", "translation": "what time is it now?", "cefr": "A1", "register": "neutral", "tags": ["time", "questions"] },
  { "schemaVersion": 1, "key": "phrase.itsu-ga-ii", "entryType": "phrase", "lemma": "いつがいいですか", "romaji": "itsu ga ii desu ka", "translation": "when is good for you?", "cefr": "A2", "register": "neutral", "tags": ["time", "scheduling"] },
  { "schemaVersion": 1, "key": "phrase.okurete-sumimasen", "entryType": "phrase", "lemma": "遅れてすみません", "reading": "おくれてすみません", "romaji": "okurete sumimasen", "translation": "sorry I'm late", "cefr": "A2", "register": "neutral", "tags": ["courtesy", "time"], "naturalMeaning": "Punctuality is taken seriously — even a few minutes late warrants this. More formal: 遅れて申し訳ありません." },
  { "schemaVersion": 1, "key": "phrase.jikan-ga-arimasen", "entryType": "phrase", "lemma": "時間がありません", "reading": "じかんがありません", "romaji": "jikan ga arimasen", "translation": "I don't have time", "cefr": "A2", "register": "neutral", "tags": ["time"] },
  { "schemaVersion": 1, "key": "phrase.chotto-ii-desuka", "entryType": "phrase", "lemma": "ちょっといいですか", "romaji": "chotto ii desu ka", "translation": "do you have a moment?", "cefr": "A2", "register": "neutral", "tags": ["conversation"], "naturalMeaning": "Gentle way to get someone's attention or ask for a quick word — 'got a sec?'." },
  { "schemaVersion": 1, "key": "phrase.gambatte", "entryType": "phrase", "lemma": "頑張ってください", "reading": "がんばってください", "romaji": "ganbatte kudasai", "translation": "good luck / do your best", "cefr": "A2", "register": "neutral", "tags": ["courtesy"], "naturalMeaning": "Encouragement before a challenge — casual 頑張って, or 頑張ってね to a friend. Not literally 'luck' but 'give it your all'." },
  { "schemaVersion": 1, "key": "phrase.sumimasen-attention", "entryType": "phrase", "lemma": "すみません、ちょっと", "romaji": "sumimasen, chotto", "translation": "excuse me... (getting attention / trailing off to decline)", "cefr": "A2", "register": "neutral", "tags": ["conversation", "courtesy"], "naturalMeaning": "ちょっと left hanging is a classic soft refusal — trailing off signals 'no' without the bluntness of saying it. Also just flags you need a moment of someone's time." },
  { "schemaVersion": 1, "key": "phrase.oikutsu-desuka", "entryType": "phrase", "lemma": "おいくつですか", "romaji": "oikutsu desu ka", "translation": "how old are you? (polite)", "cefr": "A2", "register": "formal", "tags": ["small-talk"], "naturalMeaning": "Gentler than 何歳ですか. Still, asking age directly can be sensitive with adults — read the situation." },
  { "schemaVersion": 1, "key": "phrase.mou-ichido-onegai", "entryType": "phrase", "lemma": "もう一度言ってください", "reading": "もういちどいってください", "romaji": "mou ichido itte kudasai", "translation": "please say that again", "cefr": "A1", "register": "neutral", "tags": ["communication"] },
  { "schemaVersion": 1, "key": "phrase.chotto-matte", "entryType": "phrase", "lemma": "ちょっと待ってください", "reading": "ちょっとまってください", "romaji": "chotto matte kudasai", "translation": "please wait a moment", "cefr": "A1", "register": "neutral", "tags": ["conversation"], "naturalMeaning": "Everyday 'hold on a sec'. Casual ちょっと待って among friends; polite service version is 少々お待ちください." }
