[
  {
    "schemaVersion": 1,
    "key": "dcvocab.dacha",
    "entryType": "word",
    "lemma": "дача",
    "romaji": "dácha",
    "translation": "dacha (country house with a garden plot)",
    "partOfSpeech": "noun",
    "gender": "f",
    "cefr": "A1",
    "register": "neutral",
    "naturalMeaning": "Not just a 'summer house' — a dacha is usually a modest cottage attached to a plot of land the family actively gardens, not a leisure-only retreat. See the culture notes for how deep this institution runs.",
    "tags": ["core", "place"],
    "examples": [
      { "text": "На выходных мы едем на дачу.", "romaji": "Na vykhodných my yédem na dáchu.", "translation": "We're going to the dacha this weekend." }
    ]
  },
  {
    "schemaVersion": 1,
    "key": "dcvocab.ogorod",
    "entryType": "word",
    "lemma": "огород",
    "romaji": "agaród",
    "translation": "vegetable garden plot",
    "partOfSpeech": "noun",
    "gender": "m",
    "cefr": "A1",
    "register": "neutral",
    "naturalMeaning": "The working, food-producing part of a dacha plot, as opposed to сад (the fruit-tree orchard) — most dachas have both.",
    "tags": ["core", "garden"],
    "examples": [
      { "text": "Я работаю в огороде всё утро.", "romaji": "Ya rabótayu v agaróde vsyo útra.", "translation": "I've been working in the vegetable garden all morning." }
    ]
  },
  {
