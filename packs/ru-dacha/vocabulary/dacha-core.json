    "romaji": "uchástak",
    "translation": "plot of land",
    "partOfSpeech": "noun",
    "gender": "m",
    "cefr": "A2",
    "register": "neutral",
    "naturalMeaning": "The generic legal/practical term for the land itself, however it's used — the classic Soviet allocation was six sotok (соток), about 600 square meters.",
    "tags": ["core", "place"]
  },
  {
    "schemaVersion": 1,
