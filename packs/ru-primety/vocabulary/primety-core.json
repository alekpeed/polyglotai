  {
    "schemaVersion": 1,
    "key": "pmvocab.prisest-na-dorozhku",
    "entryType": "chunk",
    "lemma": "присесть на дорожку",
    "romaji": "prisést' na darózhku",
    "translation": "to sit down for the road",
    "literalMeaning": "to sit down onto the little road",
    "naturalMeaning": "Before leaving on any trip, everyone present sits down together in silence for a few seconds — said to keep the journey safe. Skipping it can genuinely make a Russian host uneasy.",
    "cefr": "A2",
    "register": "neutral",
    "tags": ["ritual", "travel", "core"],
    "examples": [
      { "text": "Подожди, давай присядем на дорожку.", "romaji": "Padazhdí, davay prisyádem na darózhku.", "translation": "Wait, let's sit down for the road." }
    ]
  },
  {
    "schemaVersion": 1,
    "key": "pmvocab.dorozhka",
    "entryType": "word",
    "lemma": "дорожка",
    "romaji": "darózhka",
    "translation": "path / little road",
    "naturalMeaning": "A diminutive of дорога, used specifically in the на дорожку idiom — 'for the road ahead.'",
    "partOfSpeech": "noun",
    "cefr": "A2",
    "register": "neutral",
    "gender": "f",
    "tags": ["travel"]
  },
  {
    "schemaVersion": 1,
