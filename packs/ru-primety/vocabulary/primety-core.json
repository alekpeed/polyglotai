  {
    "schemaVersion": 1,
    "key": "pmvocab.posmotret-v-zerkalo",
    "entryType": "chunk",
    "lemma": "посмотреть в зеркало",
    "romaji": "pasmatrét' v zérkala",
    "translation": "to look in the mirror",
    "naturalMeaning": "If you leave home and have to go back for something forgotten, tradition says you must look at yourself in a mirror before leaving again — otherwise the trip is cursed with bad luck.",
    "cefr": "A2",
    "register": "neutral",
    "tags": ["ritual"]
  },
  {
    "schemaVersion": 1,
    "key": "pmvocab.na-vsyakiy-sluchay",
