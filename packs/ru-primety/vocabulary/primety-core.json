    "translation": "a bad omen",
    "literalMeaning": "toward bad",
    "naturalMeaning": "The mirror phrase to к добру — «Это к худу» marks something as an unlucky sign.",
    "partOfSpeech": "phrase",
    "cefr": "A2",
    "register": "neutral",
    "tags": ["core", "omen"]
  },
