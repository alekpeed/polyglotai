    "key": "pmvocab.porog",
    "entryType": "word",
    "lemma": "порог",
    "romaji": "parók",
    "translation": "threshold",
    "naturalMeaning": "The strip of floor right under a doorway — treated in Russian folk belief as a boundary between two worlds, not just a piece of the floor.",
    "partOfSpeech": "noun",
    "cefr": "A2",
    "register": "neutral",
    "gender": "m",
    "tags": ["ritual", "core"]
  },
  {
    "schemaVersion": 1,
    "key": "pmvocab.cherez-porog",
    "entryType": "phrase",
    "lemma": "через порог",
    "romaji": "chérez parók",
    "translation": "across the threshold",
    "naturalMeaning": "Used almost exclusively in the warning «не здороваться через порог» — don't shake hands, pass objects, or kiss across the threshold; step through first.",
    "cefr": "A2",
    "register": "neutral",
    "tags": ["ritual", "core"]
  },
  {
    "schemaVersion": 1,
    "key": "pmvocab.postuchat-po-derevu",
    "entryType": "chunk",
    "lemma": "постучать по дереву",
    "romaji": "pastuchát' pa dérevu",
    "translation": "to knock on wood",
    "naturalMeaning": "Said or done immediately after mentioning good fortune or good health out loud, to avoid jinxing it — functionally identical to the English gesture.",
    "cefr": "A2",
    "register": "neutral",
    "tags": ["ritual", "core"],
    "examples": [
      { "text": "Быстро, постучи по дереву!", "romaji": "Býstra, pastuchí pa dérevu!", "translation": "Quick, knock on wood!" }
    ]
  },
  {
    "schemaVersion": 1,
    "key": "pmvocab.tri-raza",
    "entryType": "phrase",
    "lemma": "три раза",
    "romaji": "tri ráza",
    "translation": "three times",
    "naturalMeaning": "The conventional count for knocking on wood or spitting over the shoulder — once is considered halfhearted.",
    "cefr": "A1",
    "register": "neutral",
    "tags": ["ritual"]
  },
