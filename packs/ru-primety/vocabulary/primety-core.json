[
  {
    "schemaVersion": 1,
    "key": "pmvocab.primeta",
    "entryType": "word",
    "lemma": "примета",
    "romaji": "priméta",
    "translation": "omen / superstitious sign",
    "naturalMeaning": "The general word for any of the beliefs in this pack — a small everyday event (a cat crossing your path, spilled salt) taken as a sign of what's coming.",
    "partOfSpeech": "noun",
    "cefr": "A1",
    "register": "neutral",
    "gender": "f",
    "tags": ["core"],
    "examples": [
      { "text": "Это старая русская примета.", "romaji": "Éta stáraya rússkaya priméta.", "translation": "This is an old Russian superstition." }
    ]
  },
  {
    "schemaVersion": 1,
    "key": "pmvocab.sueveriye",
    "entryType": "word",
    "lemma": "суеверие",
    "romaji": "suyevériye",
    "translation": "superstition (as a belief system)",
    "naturalMeaning": "More abstract than примета — примета is one specific sign, суеверие is the general habit of believing in signs.",
    "partOfSpeech": "noun",
    "cefr": "A2",
    "register": "neutral",
    "gender": "n",
    "tags": ["core"]
  },
  {
    "schemaVersion": 1,
    "key": "pmvocab.sueverny",
    "entryType": "word",
    "lemma": "суеверный",
    "romaji": "suyevérny",
    "translation": "superstitious",
    "partOfSpeech": "adjective",
    "cefr": "A2",
    "register": "neutral",
    "tags": ["core"],
    "examples": [
      { "text": "Моя бабушка очень суеверная.", "romaji": "Mayá bábushka óchen' suyevérnaya.", "translation": "My grandmother is very superstitious." }
    ]
  },
  {
    "schemaVersion": 1,
    "key": "pmvocab.verit",
    "entryType": "word",
    "lemma": "верить",
    "romaji": "vérit'",
    "translation": "to believe",
    "partOfSpeech": "verb",
    "cefr": "A1",
    "register": "neutral",
    "tags": ["core"],
    "examples": [
      { "text": "Ты веришь в приметы?", "romaji": "Ty vérish' v priméty?", "translation": "Do you believe in superstitions?" }
    ]
  },
  {
