  },
  {
    "schemaVersion": 1,
    "key": "pmvocab.ne-svisti-v-dome",
    "entryType": "chunk",
    "lemma": "не свисти в доме",
    "romaji": "nye svistí v dóme",
    "translation": "don't whistle indoors",
    "naturalMeaning": "One of the most reflexively enforced primety — whistling inside is believed to whistle your money away. Said sharply, even to children who don't know the belief.",
    "cefr": "A2",
    "register": "informal",
    "tags": ["ritual", "money", "core"]
  },
  {
    "schemaVersion": 1,
    "key": "pmvocab.deneg-ne-budet",
    "entryType": "phrase",
    "lemma": "денег не будет",
    "romaji": "dének nye búdet",
    "translation": "there won't be any money",
    "naturalMeaning": "The standard warning tacked onto the whistling superstition — the believed consequence of whistling indoors.",
    "cefr": "A2",
    "register": "neutral",
    "tags": ["money"]
  },
