[
  { "schemaVersion": 1, "key": "fbvocab.gol", "entryType": "word", "lemma": "gol", "translation": "goal", "partOfSpeech": "noun", "cefr": "A1", "ipa": "gɔw", "gender": "m", "register": "neutral", "tags": ["futebol", "core"], "examples": [{ "text": "Que golaço!", "translation": "What an amazing goal!", "register": "informal" }] },
  { "schemaVersion": 1, "key": "fbvocab.time", "entryType": "word", "lemma": "time", "translation": "team", "partOfSpeech": "noun", "cefr": "A1", "ipa": "ˈtʃi.mi", "gender": "m", "register": "neutral", "tags": ["futebol", "core"], "examples": [{ "text": "Qual é o seu time?", "translation": "What team do you support?" }] },
  { "schemaVersion": 1, "key": "fbvocab.torcida", "entryType": "word", "lemma": "torcida", "translation": "the fans / fanbase", "partOfSpeech": "noun", "cefr": "A1", "gender": "f", "register": "neutral", "tags": ["futebol", "core"], "naturalMeaning": "Refers to the whole body of supporters of a club as a collective identity, not just the people in the stadium.", "examples": [{ "text": "A torcida não parou de cantar.", "translation": "The fans never stopped singing." }] },
  { "schemaVersion": 1, "key": "fbvocab.torcedor", "entryType": "word", "lemma": "torcedor", "translation": "fan / supporter", "partOfSpeech": "noun", "cefr": "A1", "gender": "m", "register": "neutral", "tags": ["futebol", "people"], "naturalMeaning": "Feminine form is torcedora.", "examples": [{ "text": "Sou torcedor do Flamengo desde criança.", "translation": "I've been a Flamengo fan since I was a kid." }] },
  { "schemaVersion": 1, "key": "fbvocab.torcedora", "entryType": "word", "lemma": "torcedora", "translation": "fan / supporter (female)", "partOfSpeech": "noun", "cefr": "A2", "gender": "f", "register": "neutral", "tags": ["futebol", "people"] },
  { "schemaVersion": 1, "key": "fbvocab.torcer", "entryType": "word", "lemma": "torcer", "translation": "to root for / to support (a team)", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["futebol", "verb"], "naturalMeaning": "Always takes 'para' or 'por': torcer para o Brasil, torcer pelo São Paulo.", "examples": [{ "text": "Eu torço pro Corinthians.", "translation": "I root for Corinthians.", "register": "informal" }] },
  { "schemaVersion": 1, "key": "fbvocab.campeonato", "entryType": "word", "lemma": "campeonato", "translation": "championship / league", "partOfSpeech": "noun", "cefr": "A1", "gender": "m", "register": "neutral", "tags": ["futebol", "core"], "examples": [{ "text": "O campeonato começa em maio.", "translation": "The championship starts in May." }] },
  { "schemaVersion": 1, "key": "fbvocab.campeao", "entryType": "word", "lemma": "campeão", "translation": "champion", "partOfSpeech": "noun", "cefr": "A1", "ipa": "kɐ̃ˈpjɐ̃w̃", "gender": "m", "register": "neutral", "tags": ["futebol"], "naturalMeaning": "Feminine is campeã; used both for the winning team and an individual player.", "examples": [{ "text": "Somos campeões!", "translation": "We are champions!", "register": "informal" }] },
  { "schemaVersion": 1, "key": "fbvocab.goleiro", "entryType": "word", "lemma": "goleiro", "translation": "goalkeeper", "partOfSpeech": "noun", "cefr": "A1", "gender": "m", "register": "neutral", "tags": ["futebol", "positions"] },
  { "schemaVersion": 1, "key": "fbvocab.zagueiro", "entryType": "word", "lemma": "zagueiro", "translation": "center-back / defender", "partOfSpeech": "noun", "cefr": "A2", "gender": "m", "register": "neutral", "tags": ["futebol", "positions"] },
  { "schemaVersion": 1, "key": "fbvocab.lateral", "entryType": "word", "lemma": "lateral", "translation": "fullback", "partOfSpeech": "noun", "cefr": "A2", "gender": "m", "register": "neutral", "tags": ["futebol", "positions"], "naturalMeaning": "Split into lateral-direito (right back) and lateral-esquerdo (left back)." },
  { "schemaVersion": 1, "key": "fbvocab.volante", "entryType": "word", "lemma": "volante", "translation": "defensive midfielder", "partOfSpeech": "noun", "cefr": "B1", "gender": "m", "register": "neutral", "tags": ["futebol", "positions"] },
  { "schemaVersion": 1, "key": "fbvocab.meia", "entryType": "word", "lemma": "meia", "translation": "midfielder", "partOfSpeech": "noun", "cefr": "A2", "gender": "m", "register": "neutral", "tags": ["futebol", "positions"], "naturalMeaning": "The position uses 'o meia' even though 'meia' looks feminine — it's short for 'meio-campista'." },
  { "schemaVersion": 1, "key": "fbvocab.atacante", "entryType": "word", "lemma": "atacante", "translation": "forward / striker", "partOfSpeech": "noun", "cefr": "A1", "gender": "m/f", "register": "neutral", "tags": ["futebol", "positions"] },
  { "schemaVersion": 1, "key": "fbvocab.artilheiro", "entryType": "word", "lemma": "artilheiro", "translation": "top scorer", "partOfSpeech": "noun", "cefr": "B1", "gender": "m", "register": "neutral", "tags": ["futebol", "positions"], "examples": [{ "text": "Ele é o artilheiro do campeonato.", "translation": "He's the league's top scorer." }] },
  { "schemaVersion": 1, "key": "fbvocab.tecnico", "entryType": "word", "lemma": "técnico", "translation": "coach / manager", "partOfSpeech": "noun", "cefr": "A2", "gender": "m", "register": "neutral", "tags": ["futebol", "people"], "naturalMeaning": "The everyday word for a football coach; 'treinador' also exists but is a bit more formal." },
  { "schemaVersion": 1, "key": "fbvocab.juiz", "entryType": "word", "lemma": "juiz", "translation": "referee", "partOfSpeech": "noun", "cefr": "A2", "gender": "m", "register": "neutral", "tags": ["futebol", "people"], "naturalMeaning": "'Árbitro' is the more formal/technical term used on TV broadcasts." },
  { "schemaVersion": 1, "key": "fbvocab.bandeirinha", "entryType": "word", "lemma": "bandeirinha", "translation": "linesman / assistant referee", "partOfSpeech": "noun", "cefr": "B1", "gender": "m", "register": "informal", "tags": ["futebol", "people"], "literalMeaning": "little flag", "naturalMeaning": "Named after the flag the assistant referee carries; the everyday term, even though the official title is 'árbitro assistente'." },
  { "schemaVersion": 1, "key": "fbvocab.penalti", "entryType": "word", "lemma": "pênalti", "translation": "penalty kick", "partOfSpeech": "noun", "cefr": "A1", "ipa": "ˈpe.naw.tʃi", "gender": "m", "register": "neutral", "tags": ["futebol", "core"], "examples": [{ "text": "Foi pênalti, com certeza!", "translation": "That was a penalty, for sure!" }] },
  { "schemaVersion": 1, "key": "fbvocab.escalacao", "entryType": "word", "lemma": "escalação", "translation": "starting lineup", "partOfSpeech": "noun", "cefr": "A2", "gender": "f", "register": "neutral", "tags": ["futebol", "core"], "examples": [{ "text": "Saiu a escalação do jogo de hoje.", "translation": "Today's lineup has been announced." }] },
  { "schemaVersion": 1, "key": "fbvocab.titular", "entryType": "word", "lemma": "titular", "translation": "starter / starting player", "partOfSpeech": "noun", "cefr": "B1", "gender": "m/f", "register": "neutral", "tags": ["futebol", "positions"] },
  { "schemaVersion": 1, "key": "fbvocab.reserva", "entryType": "word", "lemma": "reserva", "translation": "substitute / bench player", "partOfSpeech": "noun", "cefr": "A2", "gender": "m/f", "register": "neutral", "tags": ["futebol", "positions"], "examples": [{ "text": "Ele entrou como reserva no segundo tempo.", "translation": "He came in as a substitute in the second half." }] },
  { "schemaVersion": 1, "key": "fbvocab.classico", "entryType": "word", "lemma": "clássico", "translation": "derby / big rivalry match", "partOfSpeech": "noun", "cefr": "A2", "gender": "m", "register": "neutral", "tags": ["futebol", "core"], "naturalMeaning": "Used for any high-stakes match between traditional rivals, not just city derbies — see the culture notes.", "examples": [{ "text": "Domingo tem clássico!", "translation": "There's a big rivalry match on Sunday!", "register": "informal" }] },
  { "schemaVersion": 1, "key": "fbvocab.rival", "entryType": "word", "lemma": "rival", "translation": "rival (team)", "partOfSpeech": "noun", "cefr": "A2", "gender": "m", "register": "neutral", "tags": ["futebol"] },
  { "schemaVersion": 1, "key": "fbvocab.torcida-organizada", "entryType": "word", "lemma": "torcida organizada", "translation": "organized supporters' group", "partOfSpeech": "noun", "cefr": "B1", "gender": "f", "register": "neutral", "tags": ["futebol"], "naturalMeaning": "A formal fan club with its own name, flags, and drums that organizes the choreography and chants in the stands." },
  { "schemaVersion": 1, "key": "fbvocab.narrador", "entryType": "word", "lemma": "narrador", "translation": "match commentator", "partOfSpeech": "noun", "cefr": "A2", "gender": "m", "register": "neutral", "tags": ["futebol", "people"], "naturalMeaning": "The play-by-play voice, famous above all for the long, drawn-out 'goooool' call." },
  { "schemaVersion": 1, "key": "fbvocab.gooool", "entryType": "word", "lemma": "gooooolll!", "translation": "goooooal!", "partOfSpeech": "interjection", "cefr": "A1", "register": "informal", "tags": ["futebol", "exclamation"], "naturalMeaning": "Brazilian commentators famously stretch this out for several seconds after a goal — the longer, the bigger the moment." },
  { "schemaVersion": 1, "key": "fbvocab.impedimento", "entryType": "word", "lemma": "impedimento", "translation": "offside", "partOfSpeech": "noun", "cefr": "A2", "gender": "m", "register": "neutral", "tags": ["futebol"] },
  { "schemaVersion": 1, "key": "fbvocab.falta", "entryType": "word", "lemma": "falta", "translation": "foul", "partOfSpeech": "noun", "cefr": "A1", "gender": "f", "register": "neutral", "tags": ["futebol", "core"], "examples": [{ "text": "Isso foi falta clara!", "translation": "That was a clear foul!" }] },
  { "schemaVersion": 1, "key": "fbvocab.cartao-amarelo", "entryType": "word", "lemma": "cartão amarelo", "translation": "yellow card", "partOfSpeech": "noun", "cefr": "A1", "gender": "m", "register": "neutral", "tags": ["futebol"] },
  { "schemaVersion": 1, "key": "fbvocab.cartao-vermelho", "entryType": "word", "lemma": "cartão vermelho", "translation": "red card", "partOfSpeech": "noun", "cefr": "A1", "gender": "m", "register": "neutral", "tags": ["futebol"] },
  { "schemaVersion": 1, "key": "fbvocab.escanteio", "entryType": "word", "lemma": "escanteio", "translation": "corner kick", "partOfSpeech": "noun", "cefr": "A2", "gender": "m", "register": "neutral", "tags": ["futebol"] },
  { "schemaVersion": 1, "key": "fbvocab.tiro-livre", "entryType": "word", "lemma": "tiro livre", "translation": "free kick", "partOfSpeech": "noun", "cefr": "A2", "gender": "m", "register": "neutral", "tags": ["futebol"] },
  { "schemaVersion": 1, "key": "fbvocab.bola", "entryType": "word", "lemma": "bola", "translation": "ball", "partOfSpeech": "noun", "cefr": "A1", "gender": "f", "register": "neutral", "tags": ["futebol", "core"] },
  { "schemaVersion": 1, "key": "fbvocab.estadio", "entryType": "word", "lemma": "estádio", "translation": "stadium", "partOfSpeech": "noun", "cefr": "A1", "ipa": "isˈta.dʒju", "gender": "m", "register": "neutral", "tags": ["futebol", "core"], "examples": [{ "text": "Vamos ao estádio no sábado.", "translation": "We're going to the stadium on Saturday." }] },
  { "schemaVersion": 1, "key": "fbvocab.arquibancada", "entryType": "word", "lemma": "arquibancada", "translation": "stands / bleachers", "partOfSpeech": "noun", "cefr": "A2", "gender": "f", "register": "neutral", "tags": ["futebol"] },
  { "schemaVersion": 1, "key": "fbvocab.camisa", "entryType": "word", "lemma": "camisa", "translation": "jersey / shirt", "partOfSpeech": "noun", "cefr": "A1", "gender": "f", "register": "neutral", "tags": ["futebol"], "examples": [{ "text": "Comprei a camisa nova do time.", "translation": "I bought the team's new jersey." }] },
  { "schemaVersion": 1, "key": "fbvocab.selecao", "entryType": "word", "lemma": "seleção", "translation": "national team", "partOfSpeech": "noun", "cefr": "A1", "gender": "f", "register": "neutral", "tags": ["futebol", "core"], "naturalMeaning": "'A Seleção', capitalized in speech tone, almost always means the Brazilian national team unless context says otherwise.", "examples": [{ "text": "A Seleção joga hoje à noite.", "translation": "The national team plays tonight." }] },
  { "schemaVersion": 1, "key": "fbvocab.copa", "entryType": "word", "lemma": "copa", "translation": "cup (tournament)", "partOfSpeech": "noun", "cefr": "A1", "gender": "f", "register": "neutral", "tags": ["futebol"], "naturalMeaning": "'A Copa' by itself usually means the World Cup." },
  { "schemaVersion": 1, "key": "fbvocab.taca", "entryType": "word", "lemma": "taça", "translation": "trophy", "partOfSpeech": "noun", "cefr": "A2", "gender": "f", "register": "neutral", "tags": ["futebol"] },
  { "schemaVersion": 1, "key": "fbvocab.rebaixamento", "entryType": "word", "lemma": "rebaixamento", "translation": "relegation", "partOfSpeech": "noun", "cefr": "B1", "gender": "m", "register": "neutral", "tags": ["futebol"], "naturalMeaning": "The dreaded fate of finishing near the bottom of the table and dropping to a lower division." },
  { "schemaVersion": 1, "key": "fbvocab.gol-contra", "entryType": "word", "lemma": "gol contra", "translation": "own goal", "partOfSpeech": "noun", "cefr": "A2", "gender": "m", "register": "neutral", "tags": ["futebol"] },
  { "schemaVersion": 1, "key": "fbvocab.gol-de-placa", "entryType": "phrase", "lemma": "gol de placa", "translation": "a spectacular, postcard-worthy goal", "partOfSpeech": "noun phrase", "cefr": "B1", "register": "informal", "tags": ["futebol"], "literalMeaning": "goal worthy of a plaque", "naturalMeaning": "Describes a goal so beautiful it deserves to be commemorated — high praise from commentators and fans alike." },
  { "schemaVersion": 1, "key": "fbvocab.prorrogacao", "entryType": "word", "lemma": "prorrogação", "translation": "extra time", "partOfSpeech": "noun", "cefr": "B1", "gender": "f", "register": "neutral", "tags": ["futebol"] },
  { "schemaVersion": 1, "key": "fbvocab.disputa-de-penaltis", "entryType": "phrase", "lemma": "disputa de pênaltis", "translation": "penalty shootout", "partOfSpeech": "noun phrase", "cefr": "B1", "register": "neutral", "tags": ["futebol"], "examples": [{ "text": "Vai ter disputa de pênaltis!", "translation": "There's going to be a penalty shootout!" }] },
  { "schemaVersion": 1, "key": "fbvocab.vencer", "entryType": "word", "lemma": "vencer", "translation": "to win", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["futebol", "verb"], "examples": [{ "text": "O Brasil venceu por 2 a 0.", "translation": "Brazil won 2-0." }] },
  { "schemaVersion": 1, "key": "fbvocab.perder", "entryType": "word", "lemma": "perder", "translation": "to lose", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["futebol", "verb"], "examples": [{ "text": "A gente perdeu de novo.", "translation": "We lost again.", "register": "informal" }] },
  { "schemaVersion": 1, "key": "fbvocab.empatar", "entryType": "word", "lemma": "empatar", "translation": "to draw / tie", "partOfSpeech": "verb", "cefr": "A2", "register": "neutral", "tags": ["futebol", "verb"], "examples": [{ "text": "Empatou em um a um.", "translation": "It ended in a 1-1 draw." }] },
  { "schemaVersion": 1, "key": "fbvocab.assistir-ao-jogo", "entryType": "phrase", "lemma": "assistir ao jogo", "translation": "to watch the match", "partOfSpeech": "verb phrase", "cefr": "A1", "register": "neutral", "tags": ["futebol", "core"], "naturalMeaning": "In everyday spoken Brazilian, people often drop the 'ao' and just say 'assistir o jogo'.", "examples": [{ "text": "Vamos assistir ao jogo no bar.", "translation": "Let's watch the match at the bar." }] },
  { "schemaVersion": 1, "key": "fbvocab.bora-torcer", "entryType": "phrase", "lemma": "bora torcer", "translation": "let's cheer / let's go root for them", "partOfSpeech": "interjection", "cefr": "A1", "register": "informal", "tags": ["futebol", "exclamation"], "literalMeaning": "let's [go] root", "naturalMeaning": "'Bora' is the everyday clipped form of 'vamos embora', used constantly to rally people to do something together." },
  { "schemaVersion": 1, "key": "fbvocab.isso-ai", "entryType": "phrase", "lemma": "isso aí!", "translation": "that's it! / yes!", "partOfSpeech": "interjection", "cefr": "A1", "register": "informal", "tags": ["futebol", "exclamation"], "naturalMeaning": "A general shout of approval, used constantly while watching a match for a good play, tackle, or pass." },
  { "schemaVersion": 1, "key": "fbvocab.vai-vai-vai", "entryType": "phrase", "lemma": "vai, vai, vai!", "translation": "go, go, go!", "partOfSpeech": "interjection", "cefr": "A1", "register": "informal", "tags": ["futebol", "exclamation"], "naturalMeaning": "Shouted as a player breaks away toward goal — builds in urgency the closer they get." },
  { "schemaVersion": 1, "key": "fbvocab.foi-penalti", "entryType": "phrase", "lemma": "foi pênalti!", "translation": "that was a penalty!", "partOfSpeech": "interjection", "cefr": "A1", "register": "informal", "tags": ["futebol", "exclamation"] },
  { "schemaVersion": 1, "key": "fbvocab.que-jogaco", "entryType": "phrase", "lemma": "que jogaço!", "translation": "what a great match!", "partOfSpeech": "interjection", "cefr": "A2", "register": "informal", "tags": ["futebol", "exclamation"], "naturalMeaning": "The suffix -aço makes an augmentative, turning 'jogo' (match) into an especially exciting one — same pattern as 'golaço'." },
  { "schemaVersion": 1, "key": "fbvocab.qual-e-o-seu-time", "entryType": "phrase", "lemma": "qual é o seu time?", "translation": "what team do you support?", "partOfSpeech": "phrase", "cefr": "A1", "register": "neutral", "tags": ["futebol", "core"], "naturalMeaning": "One of the most common small-talk questions in Brazil — see the culture notes on 'torcida' as identity." },
  { "schemaVersion": 1, "key": "fbvocab.sou-do", "entryType": "phrase", "lemma": "sou do Flamengo", "translation": "I support Flamengo", "partOfSpeech": "phrase", "cefr": "A1", "register": "neutral", "tags": ["futebol", "core"], "naturalMeaning": "Pattern: 'sou do/da + [team]' — the standard way to state your team, treated almost like stating your hometown. Swap in any team name.", "examples": [{ "text": "Sou do Palmeiras, e você?", "translation": "I support Palmeiras, and you?" }] }
]
