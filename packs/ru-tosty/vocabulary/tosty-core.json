[
  { "schemaVersion": 1, "key": "tsvocab.tost", "entryType": "word", "lemma": "тост", "romaji": "tost", "translation": "toast", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "m", "tags": ["core", "toasting"], "naturalMeaning": "Not just a one-word 'cheers' — a Russian тост is expected to be a short spoken piece, sometimes a whole little speech. See the culture notes.", "examples": [{ "text": "Кто скажет тост?", "romaji": "Kto skázhet tost?", "translation": "Who's going to give a toast?" }] },
  { "schemaVersion": 1, "key": "tsvocab.proiznesti-tost", "entryType": "phrase", "lemma": "произнести тост", "romaji": "proiznestí tost", "translation": "to give / deliver a toast", "literalMeaning": "to pronounce a toast", "partOfSpeech": "verb phrase", "cefr": "A2", "register": "neutral", "tags": ["core", "toasting"], "examples": [{ "text": "Сейчас я хочу произнести тост.", "romaji": "Seychás ya khachú proiznestí tost.", "translation": "Now I'd like to give a toast." }] },
  { "schemaVersion": 1, "key": "tsvocab.podnyat-bokal", "entryType": "phrase", "lemma": "поднять бокал", "romaji": "padnyát' bakál", "translation": "to raise a glass", "partOfSpeech": "verb phrase", "cefr": "A1", "register": "neutral", "tags": ["core", "toasting"], "examples": [{ "text": "Давайте поднимем бокалы!", "romaji": "Daváyte padnímyem bakály!", "translation": "Let's raise our glasses!" }] },
  { "schemaVersion": 1, "key": "tsvocab.choknutsya", "entryType": "word", "lemma": "чокнуться", "romaji": "chóknut'sya", "translation": "to clink glasses (with someone)", "partOfSpeech": "verb", "cefr": "A2", "register": "neutral", "tags": ["core", "toasting", "superstition"], "naturalMeaning": "Said to require eye contact with the person you're clinking with, or you risk seven years of bad luck (often specifically bad luck in love). A real, still-widely-observed superstition — see the culture notes.", "examples": [{ "text": "Давай чокнемся!", "romaji": "Davái chóknyemsya!", "translation": "Let's clink glasses!" }] },
  { "schemaVersion": 1, "key": "tsvocab.bokal", "entryType": "word", "lemma": "бокал", "romaji": "bakál", "translation": "glass / goblet (for wine)", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "m", "tags": ["toasting", "objects"] },
  { "schemaVersion": 1, "key": "tsvocab.ryumka", "entryType": "word", "lemma": "рюмка", "romaji": "ryúmka", "translation": "shot glass", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "f", "tags": ["toasting", "objects"], "naturalMeaning": "The standard vessel for vodka toasts specifically — distinct from a бокал, which is for wine." },
  { "schemaVersion": 1, "key": "tsvocab.fuzher", "entryType": "word", "lemma": "фужер", "romaji": "fuzhér", "translation": "champagne flute", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "gender": "m", "tags": ["toasting", "objects"] },
  { "schemaVersion": 1, "key": "tsvocab.tamada", "entryType": "word", "lemma": "тамада", "romaji": "tamadá", "translation": "toastmaster", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "gender": "m", "tags": ["core", "people", "wedding"], "naturalMeaning": "A semi-formal master of ceremonies at a wedding or big celebration who structures the whole evening around a planned sequence of toasts, calling on guests one by one. A tradition especially strong in the Caucasus, widely adopted across Russian celebrations more broadly. See the culture notes.", "examples": [{ "text": "Тамада объявил следующий тост.", "romaji": "Tamadá ob'yavíl slyéduyushchiy tost.", "translation": "The toastmaster announced the next toast." }] },
  { "schemaVersion": 1, "key": "tsvocab.slovo", "entryType": "word", "lemma": "слово", "romaji": "slóvo", "translation": "word; \"the floor\" (in a speech-giving sense)", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "n", "tags": ["toasting", "wedding"] },
  { "schemaVersion": 1, "key": "tsvocab.dat-slovo", "entryType": "phrase", "lemma": "дать слово", "romaji": "dat' slóvo", "translation": "to give someone the floor (to speak)", "literalMeaning": "to give the word", "partOfSpeech": "verb phrase", "cefr": "A2", "register": "neutral", "tags": ["core", "toasting", "wedding"], "naturalMeaning": "What a тамада does before each toast — calls a guest by name and 'gives them the word' to speak.", "examples": [{ "text": "Тамада даёт слово другу жениха.", "romaji": "Tamadá dayót slóvo drúgu zhenikhá.", "translation": "The toastmaster gives the floor to the groom's friend." }] },
  { "schemaVersion": 1, "key": "tsvocab.vzyat-slovo", "entryType": "phrase", "lemma": "взять слово", "romaji": "vzyat' slóvo", "translation": "to take the floor (to speak)", "partOfSpeech": "verb phrase", "cefr": "A2", "register": "neutral", "tags": ["toasting", "wedding"] },
  { "schemaVersion": 1, "key": "tsvocab.za-zdorovye", "entryType": "phrase", "lemma": "за здоровье!", "romaji": "za zdaróv'ye!", "translation": "to health!", "literalMeaning": "for [the] health", "partOfSpeech": "interjection", "cefr": "A1", "register": "neutral", "tags": ["core", "toasting", "toast-theme"], "naturalMeaning": "One of the most universal toast themes — safe to use in almost any gathering, formal or casual." },
  { "schemaVersion": 1, "key": "tsvocab.za-lyubov", "entryType": "phrase", "lemma": "за любовь!", "romaji": "za lyubóv'!", "translation": "to love!", "partOfSpeech": "interjection", "cefr": "A1", "register": "neutral", "tags": ["core", "toasting", "toast-theme"] },
  { "schemaVersion": 1, "key": "tsvocab.za-roditeley", "entryType": "phrase", "lemma": "за родителей!", "romaji": "za radítyeley!", "translation": "to [our/the] parents!", "partOfSpeech": "interjection", "cefr": "A2", "register": "neutral", "tags": ["core", "toasting", "toast-theme", "wedding"], "naturalMeaning": "A classic early toast at a wedding, offered in gratitude to both sets of parents — often genuinely emotional rather than just formal." },
  { "schemaVersion": 1, "key": "tsvocab.za-otsutstvuyushchikh-druzey", "entryType": "phrase", "lemma": "за отсутствующих друзей", "romaji": "za atsútstvuyushchikh druzéy", "translation": "to absent friends", "partOfSpeech": "interjection", "cefr": "B1", "register": "neutral", "tags": ["toasting", "toast-theme"], "naturalMeaning": "A traditional theme raised in memory of, or in solidarity with, friends who couldn't be at the table — often a quieter, more reflective toast among the rounds." },
  { "schemaVersion": 1, "key": "tsvocab.za-vstrechu", "entryType": "phrase", "lemma": "за встречу!", "romaji": "za vstréchu!", "translation": "to this meeting! / to being together again!", "partOfSpeech": "interjection", "cefr": "A2", "register": "neutral", "tags": ["core", "toasting", "toast-theme"], "naturalMeaning": "The classic toast for a reunion — old friends or family seeing each other again after time apart." },
  { "schemaVersion": 1, "key": "tsvocab.za-mir", "entryType": "phrase", "lemma": "за мир!", "romaji": "za mir!", "translation": "to peace!", "partOfSpeech": "interjection", "cefr": "A1", "register": "neutral", "tags": ["toasting", "toast-theme"], "naturalMeaning": "A common toast theme at family gatherings, often paired with 'за мир во всём мире' (to peace in the whole world)." },
  { "schemaVersion": 1, "key": "tsvocab.vashe-zdorovye", "entryType": "phrase", "lemma": "Ваше здоровье!", "romaji": "Váshe zdaróv'ye!", "translation": "your health! (formal)", "partOfSpeech": "interjection", "cefr": "A1", "register": "formal", "tags": ["core", "toasting"], "naturalMeaning": "Uses the formal/plural вы-possessive — appropriate toward an older host, a boss, or a group." },
  { "schemaVersion": 1, "key": "tsvocab.do-dna", "entryType": "phrase", "lemma": "До дна!", "romaji": "Da dna!", "translation": "Bottoms up!", "literalMeaning": "to the bottom", "partOfSpeech": "interjection", "cefr": "A1", "register": "informal", "tags": ["core", "toasting"], "naturalMeaning": "An instruction to finish the whole glass after the toast, not just sip — often followed by someone jokingly adding 'дай Бог не последний' ('God willing, not the last one')." },
  { "schemaVersion": 1, "key": "tsvocab.gorko", "entryType": "word", "lemma": "Горько!", "romaji": "Gór'ka!", "translation": "\"Bitter!\" (wedding chant)", "partOfSpeech": "interjection", "cefr": "A2", "register": "informal", "tags": ["toasting", "wedding", "superstition"], "naturalMeaning": "Literally means 'it's bitter' — guests shout it at a wedding to complain that the wine tastes bitter, and the newlyweds must kiss to 'sweeten' it. Often chanted repeatedly and playfully throughout the reception." },
  { "schemaVersion": 1, "key": "tsvocab.svadba", "entryType": "word", "lemma": "свадьба", "romaji": "svád'ba", "translation": "wedding", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "f", "tags": ["core", "wedding"] },
  { "schemaVersion": 1, "key": "tsvocab.zhenikh", "entryType": "word", "lemma": "жених", "romaji": "zheníkh", "translation": "groom", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "m", "tags": ["wedding", "people"] },
  { "schemaVersion": 1, "key": "tsvocab.nevesta", "entryType": "word", "lemma": "невеста", "romaji": "nevyésta", "translation": "bride", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "f", "tags": ["wedding", "people"] },
  { "schemaVersion": 1, "key": "tsvocab.gost", "entryType": "word", "lemma": "гость", "romaji": "gost'", "translation": "guest", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "m", "tags": ["core", "people"] },
  { "schemaVersion": 1, "key": "tsvocab.khozyain", "entryType": "word", "lemma": "хозяин", "romaji": "khazyáin", "translation": "host", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "gender": "m", "tags": ["people"] },
  { "schemaVersion": 1, "key": "tsvocab.khozyayka", "entryType": "word", "lemma": "хозяйка", "romaji": "khazyáyka", "translation": "hostess", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "gender": "f", "tags": ["people"] },
  { "schemaVersion": 1, "key": "tsvocab.zastolye", "entryType": "word", "lemma": "застолье", "romaji": "zastól'ye", "translation": "a feast / gathering around the table", "partOfSpeech": "noun", "cefr": "B1", "register": "neutral", "gender": "n", "tags": ["core", "toasting"], "naturalMeaning": "A long, sociable sit-down meal built around courses, conversation, and rounds of toasting — the setting in which the whole toasting ritual plays out." },
  { "schemaVersion": 1, "key": "tsvocab.ochered", "entryType": "word", "lemma": "очередь", "romaji": "óchered'", "translation": "turn / line", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "gender": "f", "tags": ["toasting"] },
  { "schemaVersion": 1, "key": "tsvocab.chya-ochered", "entryType": "phrase", "lemma": "чья очередь?", "romaji": "ch'ya óchered'?", "translation": "whose turn is it?", "partOfSpeech": "phrase", "cefr": "A2", "register": "neutral", "tags": ["toasting"], "examples": [{ "text": "Чья очередь говорить тост?", "romaji": "Ch'ya óchered' gavarít' tost?", "translation": "Whose turn is it to give a toast?" }] },
  { "schemaVersion": 1, "key": "tsvocab.pozhelanie", "entryType": "word", "lemma": "пожелание", "romaji": "pazhelániye", "translation": "wish / well-wishing", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "gender": "n", "tags": ["toasting"], "naturalMeaning": "The content of most toasts is really a пожелание — a wish for the person or people being toasted, not just an announcement of the theme." },
  { "schemaVersion": 1, "key": "tsvocab.rech", "entryType": "word", "lemma": "речь", "romaji": "rech'", "translation": "speech", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "gender": "f", "tags": ["toasting"] },
  { "schemaVersion": 1, "key": "tsvocab.nalit", "entryType": "word", "lemma": "налить", "romaji": "nalít'", "translation": "to pour (a drink)", "partOfSpeech": "verb", "cefr": "A2", "register": "neutral", "tags": ["toasting"], "examples": [{ "text": "Налей мне ещё, пожалуйста.", "romaji": "Naléy mnye yeshchó, pazhálusta.", "translation": "Pour me a bit more, please." }] },
  { "schemaVersion": 1, "key": "tsvocab.polnyy-bokal", "entryType": "phrase", "lemma": "полный бокал", "romaji": "pólnyy bakál", "translation": "a full glass", "partOfSpeech": "noun phrase", "cefr": "A2", "register": "neutral", "tags": ["toasting", "superstition"], "naturalMeaning": "Toasting is expected to be done with a full glass — topping up right before a toast is normal and expected, not impatient." },
  { "schemaVersion": 1, "key": "tsvocab.pustoy-bokal", "entryType": "phrase", "lemma": "пустой бокал", "romaji": "pustóy bakál", "translation": "an empty glass", "partOfSpeech": "noun phrase", "cefr": "A2", "register": "neutral", "tags": ["toasting", "superstition"], "naturalMeaning": "Toasting with an empty glass is considered bad luck — see the culture notes on the empty-glass and water taboos." },
  { "schemaVersion": 1, "key": "tsvocab.pit-tost-vodoy", "entryType": "phrase", "lemma": "пить тост водой", "romaji": "pit' tost vadóy", "translation": "to drink a toast with water", "partOfSpeech": "verb phrase", "cefr": "B1", "register": "neutral", "tags": ["toasting", "superstition"], "naturalMeaning": "A genuinely observed taboo, not a joke: drinking a toast with water instead of an alcoholic drink is associated with wishing death on the person being toasted. See the culture notes." },
  { "schemaVersion": 1, "key": "tsvocab.smotret-v-glaza", "entryType": "phrase", "lemma": "смотреть в глаза", "romaji": "smatryét' v glazá", "translation": "to look (someone) in the eyes", "partOfSpeech": "verb phrase", "cefr": "A2", "register": "neutral", "tags": ["core", "toasting", "superstition"], "naturalMeaning": "Required etiquette the instant glasses clink — breaking eye contact is the superstition trigger, not the clinking itself." },
  { "schemaVersion": 1, "key": "tsvocab.primeta", "entryType": "word", "lemma": "примета", "romaji": "primyéta", "translation": "omen / superstition / sign", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "gender": "f", "tags": ["superstition"] },
  { "schemaVersion": 1, "key": "tsvocab.plokhaya-primeta", "entryType": "phrase", "lemma": "плохая примета", "romaji": "plakháya primyéta", "translation": "a bad omen", "partOfSpeech": "noun phrase", "cefr": "A2", "register": "neutral", "tags": ["core", "superstition"], "examples": [{ "text": "Не чокаться без взгляда — плохая примета.", "romaji": "Nye chókatsya byez vzglyáda — plakháya primyéta.", "translation": "Clinking without eye contact is a bad omen." }] },
  { "schemaVersion": 1, "key": "tsvocab.ot-vsego-serdtsa", "entryType": "phrase", "lemma": "от всего сердца", "romaji": "at fsyevó syértsa", "translation": "from the bottom of the heart", "literalMeaning": "from all of the heart", "partOfSpeech": "adverbial phrase", "cefr": "B1", "register": "neutral", "tags": ["toasting"], "naturalMeaning": "A common way to preface or close a warm, sincere toast — signals that what follows isn't just polite formula." },
  { "schemaVersion": 1, "key": "tsvocab.pervyy-tost", "entryType": "phrase", "lemma": "первый тост", "romaji": "pyérvyy tost", "translation": "the first toast", "partOfSpeech": "noun phrase", "cefr": "A2", "register": "neutral", "tags": ["toasting"], "naturalMeaning": "Traditionally more formal and general in theme — the toasts get warmer and more personal as the evening goes on. See the culture notes." },
  { "schemaVersion": 1, "key": "tsvocab.posledniy-tost", "entryType": "phrase", "lemma": "последний тост", "romaji": "paslyédniy tost", "translation": "the last / closing toast", "partOfSpeech": "noun phrase", "cefr": "A2", "register": "neutral", "tags": ["core", "toasting"] },
  { "schemaVersion": 1, "key": "tsvocab.predlozhit-tost", "entryType": "phrase", "lemma": "предложить тост", "romaji": "predlazhít' tost", "translation": "to propose a toast", "partOfSpeech": "verb phrase", "cefr": "A2", "register": "neutral", "tags": ["core", "toasting"], "examples": [{ "text": "Можно я предложу тост?", "romaji": "Mózhna ya predlazhú tost?", "translation": "May I propose a toast?" }] },
  { "schemaVersion": 1, "key": "tsvocab.kompaniya", "entryType": "word", "lemma": "компания", "romaji": "kampániya", "translation": "company / group of people (gathered together)", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "gender": "f", "tags": ["toasting"] }
]
