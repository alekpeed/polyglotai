[
  {
    "schemaVersion": 1,
    "key": "dlg.self-introduction",
    "scenario": "Meeting someone for the first time",
    "speakers": [
      { "id": "a", "name": "Анна", "role": "new acquaintance" },
      { "id": "b", "name": "You" }
    ],
    "targetLevel": "A1",
    "formality": "formal",
    "transcript": [
      { "speakerId": "a", "text": "Здравствуйте! Меня зовут Анна. А как вас зовут?", "romaji": "Zdrávstvuyte! Menyá zavút Ánna. A kak vas zavút?" },
      { "speakerId": "b", "text": "Здравствуйте! Меня зовут Джон. Очень приятно.", "romaji": "Zdrávstvuyte! Menyá zavút Dzhon. Óchen' priyátno." },
      { "speakerId": "a", "text": "Очень приятно. Вы говорите по-русски?", "romaji": "Óchen' priyátno. Vy gavaríte pa-rússki?" },
      { "speakerId": "b", "text": "Да, немного. Я живу в Москве.", "romaji": "Da, nyemnógo. Ya zhivú v Maskvyé." },
      { "speakerId": "a", "text": "Отлично! До свидания.", "romaji": "Atlíchno! Da svidániya." },
      { "speakerId": "b", "text": "До свидания!", "romaji": "Da svidániya!" }
    ],
    "translation": [
      { "speakerId": "a", "text": "Hello! My name is Anna. And what's your name?" },
      { "speakerId": "b", "text": "Hello! My name is John. Nice to meet you." },
      { "speakerId": "a", "text": "Nice to meet you too. Do you speak Russian?" },
      { "speakerId": "b", "text": "Yes, a little. I live in Moscow." },
      { "speakerId": "a", "text": "Great! Goodbye." },
      { "speakerId": "b", "text": "Goodbye!" }
    ],
    "keyVocabulary": ["vocab.zdravstvuyte", "vocab.zvat", "vocab.govorit", "vocab.zhit", "vocab.do-svidaniya"],
    "grammarNotes": "Меня зовут (literally 'they call me') is the standard way to give your name — there's no direct verb 'to be named' the way English has. Note вы here, not ты — a first meeting between adults defaults to the formal/polite form."
  },
  {
    "schemaVersion": 1,
    "key": "dlg.cafe-order",
    "scenario": "Ordering tea at a café",
    "speakers": [
      { "id": "staff", "name": "Staff", "role": "cafe staff" },
      { "id": "customer", "name": "You" }
    ],
    "targetLevel": "A1",
    "formality": "formal",
    "transcript": [
      { "speakerId": "staff", "text": "Здравствуйте! Что вы хотите?", "romaji": "Zdrávstvuyte! Shto vy khatíte?" },
      { "speakerId": "customer", "text": "Здравствуйте. Чай, пожалуйста.", "romaji": "Zdrávstvuyte. Chay, pazhálusta." },
      { "speakerId": "staff", "text": "Хорошо. Что-нибудь ещё?", "romaji": "Kharashó. Shto-nibúd' yeshchó?" },
      { "speakerId": "customer", "text": "Нет, спасибо. Это всё.", "romaji": "Nyet, spasíbo. Eto vsyo." },
      { "speakerId": "staff", "text": "Пожалуйста, вот ваш чай.", "romaji": "Pazhálusta, vot vash chay." },
      { "speakerId": "customer", "text": "Спасибо большое!", "romaji": "Spasíbo bal'shóye!" }
    ],
    "translation": [
      { "speakerId": "staff", "text": "Hello! What would you like?" },
      { "speakerId": "customer", "text": "Hello. Tea, please." },
      { "speakerId": "staff", "text": "Okay. Anything else?" },
      { "speakerId": "customer", "text": "No, thank you. That's all." },
      { "speakerId": "staff", "text": "Here you go, here's your tea." },
      { "speakerId": "customer", "text": "Thank you very much!" }
    ],
    "keyVocabulary": ["vocab.zdravstvuyte", "vocab.khotet", "vocab.chay", "vocab.pozhaluysta", "vocab.net", "vocab.spasibo"],
    "grammarNotes": "Пожалуйста does double duty in this exchange — 'please' when the customer orders, and 'here you go' when the staff hands the tea over, the same word covering both a request and a presenting gesture."
  },
