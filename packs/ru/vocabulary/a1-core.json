[
  { "schemaVersion": 1, "key": "vocab.privet", "entryType": "word", "lemma": "привет", "romaji": "privét", "translation": "hi", "partOfSpeech": "interjection", "cefr": "A1", "register": "informal", "tags": ["greeting"], "naturalMeaning": "Casual, friends-only. The neutral/polite greeting is здравствуйте." },
  { "schemaVersion": 1, "key": "vocab.zdravstvuyte", "entryType": "word", "lemma": "здравствуйте", "romaji": "zdrávstvuyte", "translation": "hello (formal)", "partOfSpeech": "interjection", "cefr": "A1", "register": "formal", "tags": ["greeting"], "naturalMeaning": "The safe default with strangers, older people, and anyone you'd address as вы. Literally wishes good health.", "examples": [{ "text": "Здравствуйте, меня зовут Анна.", "romaji": "Zdrávstvuyte, menyá zovút Ánna.", "translation": "Hello, my name is Anna." }] },
  { "schemaVersion": 1, "key": "vocab.dobroe-utro", "entryType": "phrase", "lemma": "доброе утро", "romaji": "dóbroye útro", "translation": "good morning", "partOfSpeech": "phrase", "cefr": "A1", "register": "neutral", "tags": ["greeting", "time"] },
  { "schemaVersion": 1, "key": "vocab.dobryy-vecher", "entryType": "phrase", "lemma": "добрый вечер", "romaji": "dóbryy véchyer", "translation": "good evening", "partOfSpeech": "phrase", "cefr": "A1", "register": "neutral", "tags": ["greeting", "time"] },
  { "schemaVersion": 1, "key": "vocab.do-svidaniya", "entryType": "phrase", "lemma": "до свидания", "romaji": "da svidániya", "translation": "goodbye", "partOfSpeech": "phrase", "cefr": "A1", "register": "neutral", "tags": ["greeting"], "naturalMeaning": "Literally 'until the meeting' — the safe, neutral goodbye. Casual пока (poká) is friends-only." },
  { "schemaVersion": 1, "key": "vocab.poka", "entryType": "word", "lemma": "пока", "romaji": "poká", "translation": "bye (casual)", "partOfSpeech": "interjection", "cefr": "A1", "register": "informal", "tags": ["greeting"] },
  { "schemaVersion": 1, "key": "vocab.spasibo", "entryType": "word", "lemma": "спасибо", "romaji": "spasíbo", "translation": "thank you", "partOfSpeech": "interjection", "cefr": "A1", "register": "neutral", "tags": ["courtesy"], "naturalMeaning": "Literally a contraction of 'спаси Бог' ('God save [you]'), though nobody thinks of it that way anymore." },
  { "schemaVersion": 1, "key": "vocab.pozhaluysta", "entryType": "word", "lemma": "пожалуйста", "romaji": "pazhálusta", "translation": "please / you're welcome", "partOfSpeech": "interjection", "cefr": "A1", "register": "neutral", "tags": ["courtesy"], "naturalMeaning": "Does double duty — both 'please' when asking and the standard reply to спасибо, like English 'you're welcome'.", "pronunciationNotes": "The л is often barely pronounced in fast speech — closer to 'pa-zhal-sta'." },
  { "schemaVersion": 1, "key": "vocab.izvinite", "entryType": "word", "lemma": "извините", "romaji": "izviníte", "translation": "excuse me / sorry", "partOfSpeech": "interjection", "cefr": "A1", "register": "neutral", "tags": ["courtesy"], "examples": [{ "text": "Извините, где метро?", "romaji": "Izviníte, gde metró?", "translation": "Excuse me, where's the metro?" }] },
  { "schemaVersion": 1, "key": "vocab.da", "entryType": "word", "lemma": "да", "romaji": "da", "translation": "yes", "partOfSpeech": "particle", "cefr": "A1", "register": "neutral", "tags": ["basics"] },
  { "schemaVersion": 1, "key": "vocab.net", "entryType": "word", "lemma": "нет", "romaji": "nyet", "translation": "no", "partOfSpeech": "particle", "cefr": "A1", "register": "neutral", "tags": ["basics"], "naturalMeaning": "Also means 'there isn't/there aren't' as a standalone sentence: У меня нет времени ('I don't have time', literally 'by me there-is-not time')." },
  { "schemaVersion": 1, "key": "vocab.ya", "entryType": "word", "lemma": "я", "romaji": "ya", "translation": "I", "partOfSpeech": "pronoun", "cefr": "A1", "register": "neutral", "tags": ["basics", "pronouns"] },
  { "schemaVersion": 1, "key": "vocab.ty", "entryType": "word", "lemma": "ты", "romaji": "ty", "translation": "you (informal, singular)", "partOfSpeech": "pronoun", "cefr": "A1", "register": "informal", "tags": ["basics", "pronouns"], "naturalMeaning": "Used with friends, family, children, and peers your own age you're on casual terms with." },
  { "schemaVersion": 1, "key": "vocab.vy", "entryType": "word", "lemma": "вы", "romaji": "vy", "translation": "you (formal / plural)", "partOfSpeech": "pronoun", "cefr": "A1", "register": "formal", "tags": ["basics", "pronouns"], "naturalMeaning": "The polite singular 'you' with strangers/elders, and also the only plural 'you' — context tells them apart." },
  { "schemaVersion": 1, "key": "vocab.on", "entryType": "word", "lemma": "он", "romaji": "on", "translation": "he", "partOfSpeech": "pronoun", "cefr": "A1", "register": "neutral", "tags": ["basics", "pronouns"] },
  { "schemaVersion": 1, "key": "vocab.ona", "entryType": "word", "lemma": "она", "romaji": "ona", "translation": "she", "partOfSpeech": "pronoun", "cefr": "A1", "register": "neutral", "tags": ["basics", "pronouns"] },
  { "schemaVersion": 1, "key": "vocab.my", "entryType": "word", "lemma": "мы", "romaji": "my", "translation": "we", "partOfSpeech": "pronoun", "cefr": "A1", "register": "neutral", "tags": ["basics", "pronouns"] },
  { "schemaVersion": 1, "key": "vocab.oni", "entryType": "word", "lemma": "они", "romaji": "oní", "translation": "they", "partOfSpeech": "pronoun", "cefr": "A1", "register": "neutral", "tags": ["basics", "pronouns"] },
  { "schemaVersion": 1, "key": "vocab.odin", "entryType": "word", "lemma": "один", "romaji": "odín", "translation": "one", "partOfSpeech": "numeral", "cefr": "A1", "register": "neutral", "tags": ["numbers"], "naturalMeaning": "Uniquely among Russian numerals, один changes form by gender: один (m), одна (f), одно (n)." },
  { "schemaVersion": 1, "key": "vocab.dva", "entryType": "word", "lemma": "два", "romaji": "dva", "translation": "two", "partOfSpeech": "numeral", "cefr": "A1", "register": "neutral", "tags": ["numbers"], "naturalMeaning": "Also gender-sensitive: два (m/n) vs две (f) — почти уникально among the numerals past один." },
  { "schemaVersion": 1, "key": "vocab.tri", "entryType": "word", "lemma": "три", "romaji": "tri", "translation": "three", "partOfSpeech": "numeral", "cefr": "A1", "register": "neutral", "tags": ["numbers"] },
  { "schemaVersion": 1, "key": "vocab.chetyre", "entryType": "word", "lemma": "четыре", "romaji": "chetýre", "translation": "four", "partOfSpeech": "numeral", "cefr": "A1", "register": "neutral", "tags": ["numbers"] },
  { "schemaVersion": 1, "key": "vocab.pyat", "entryType": "word", "lemma": "пять", "romaji": "pyat'", "translation": "five", "partOfSpeech": "numeral", "cefr": "A1", "register": "neutral", "tags": ["numbers"], "naturalMeaning": "The trailing ь (soft sign) softens the т — no vowel follows it, it's a pronunciation marker, not a silent letter to ignore." },
  { "schemaVersion": 1, "key": "vocab.shest", "entryType": "word", "lemma": "шесть", "romaji": "shest'", "translation": "six", "partOfSpeech": "numeral", "cefr": "A1", "register": "neutral", "tags": ["numbers"] },
  { "schemaVersion": 1, "key": "vocab.sem", "entryType": "word", "lemma": "семь", "romaji": "syem'", "translation": "seven", "partOfSpeech": "numeral", "cefr": "A1", "register": "neutral", "tags": ["numbers"] },
  { "schemaVersion": 1, "key": "vocab.vosem", "entryType": "word", "lemma": "восемь", "romaji": "vósyem'", "translation": "eight", "partOfSpeech": "numeral", "cefr": "A1", "register": "neutral", "tags": ["numbers"] },
  { "schemaVersion": 1, "key": "vocab.devyat", "entryType": "word", "lemma": "девять", "romaji": "dévyat'", "translation": "nine", "partOfSpeech": "numeral", "cefr": "A1", "register": "neutral", "tags": ["numbers"] },
  { "schemaVersion": 1, "key": "vocab.desyat", "entryType": "word", "lemma": "десять", "romaji": "désyat'", "translation": "ten", "partOfSpeech": "numeral", "cefr": "A1", "register": "neutral", "tags": ["numbers"] },
  { "schemaVersion": 1, "key": "vocab.segodnya", "entryType": "word", "lemma": "сегодня", "romaji": "sevódnya", "translation": "today", "partOfSpeech": "adverb", "cefr": "A1", "register": "neutral", "tags": ["time"], "pronunciationNotes": "Written with a г but pronounced 'v' — one of the few genuinely irregular spelling-to-sound mismatches in Russian, a fossil of an old genitive ending." },
  { "schemaVersion": 1, "key": "vocab.zavtra", "entryType": "word", "lemma": "завтра", "romaji": "závtra", "translation": "tomorrow", "partOfSpeech": "adverb", "cefr": "A1", "register": "neutral", "tags": ["time"] },
  { "schemaVersion": 1, "key": "vocab.vchera", "entryType": "word", "lemma": "вчера", "romaji": "vcherá", "translation": "yesterday", "partOfSpeech": "adverb", "cefr": "A1", "register": "neutral", "tags": ["time"] },
  { "schemaVersion": 1, "key": "vocab.seychas", "entryType": "word", "lemma": "сейчас", "romaji": "seychás", "translation": "now", "partOfSpeech": "adverb", "cefr": "A1", "register": "neutral", "tags": ["time"] },
  { "schemaVersion": 1, "key": "vocab.semya", "entryType": "word", "lemma": "семья", "romaji": "sem'yá", "translation": "family", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "f", "tags": ["family"] },
  { "schemaVersion": 1, "key": "vocab.mama", "entryType": "word", "lemma": "мама", "romaji": "máma", "translation": "mom", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "f", "tags": ["family"] },
  { "schemaVersion": 1, "key": "vocab.papa", "entryType": "word", "lemma": "папа", "romaji": "pápa", "translation": "dad", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "m", "tags": ["family"], "naturalMeaning": "Ends in -а like a feminine noun, but grammatically masculine — a small but real exception class (папа, дядя 'uncle', мужчина 'man') worth flagging early." },
  { "schemaVersion": 1, "key": "vocab.brat", "entryType": "word", "lemma": "брат", "romaji": "brat", "translation": "brother", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "m", "tags": ["family"] },
  { "schemaVersion": 1, "key": "vocab.sestra", "entryType": "word", "lemma": "сестра", "romaji": "sestrá", "translation": "sister", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "f", "tags": ["family"] },
  { "schemaVersion": 1, "key": "vocab.drug", "entryType": "word", "lemma": "друг", "romaji": "druk", "translation": "friend", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "m", "tags": ["family", "people"], "pronunciationNotes": "Final г devoices to 'k' at the end of a word — a general Russian rule, not specific to this word." },
  { "schemaVersion": 1, "key": "vocab.voda", "entryType": "word", "lemma": "вода", "romaji": "vadá", "translation": "water", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "f", "tags": ["food-drink"], "pronunciationNotes": "Unstressed о is reduced to an 'a' sound (akanye) — vadá, not vodá, even though it's spelled with о." },
  { "schemaVersion": 1, "key": "vocab.chay", "entryType": "word", "lemma": "чай", "romaji": "chay", "translation": "tea", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "m", "tags": ["food-drink"] },
  { "schemaVersion": 1, "key": "vocab.khleb", "entryType": "word", "lemma": "хлеб", "romaji": "khlyep", "translation": "bread", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "m", "tags": ["food-drink"] },
  { "schemaVersion": 1, "key": "vocab.moloko", "entryType": "word", "lemma": "молоко", "romaji": "malakó", "translation": "milk", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "n", "tags": ["food-drink"], "pronunciationNotes": "A textbook akanye example: all three о's are spelled the same, but only the last (stressed) one is a full 'o' — the other two reduce to 'a'." },
  { "schemaVersion": 1, "key": "vocab.est", "entryType": "word", "lemma": "есть", "romaji": "yest'", "translation": "to eat / there is", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb"], "naturalMeaning": "Two unrelated meanings collide in one spelling: 'to eat' and the existential 'there is/are' (У меня есть кот, 'I have a cat', literally 'by me there-is a cat').", "examples": [{ "text": "Я хочу есть.", "romaji": "Ya khachú yest'.", "translation": "I want to eat." }] },
  { "schemaVersion": 1, "key": "vocab.pit", "entryType": "word", "lemma": "пить", "romaji": "pit'", "translation": "to drink", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb"] },
  { "schemaVersion": 1, "key": "vocab.govorit", "entryType": "word", "lemma": "говорить", "romaji": "gavarít'", "translation": "to speak / to say", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb"], "examples": [{ "text": "Я говорю по-русски.", "romaji": "Ya gavaryú pa-rússki.", "translation": "I speak Russian." }] },
  { "schemaVersion": 1, "key": "vocab.idti", "entryType": "word", "lemma": "идти", "romaji": "idtí", "translation": "to go (on foot)", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb"], "naturalMeaning": "Russian splits 'to go' by method and by whether it's a one-time or habitual/repeated trip — идти is on-foot, one direction, happening now or once; ходить is the habitual counterpart." },
  { "schemaVersion": 1, "key": "vocab.videt", "entryType": "word", "lemma": "видеть", "romaji": "vídyet'", "translation": "to see", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb"] },
  { "schemaVersion": 1, "key": "vocab.znat", "entryType": "word", "lemma": "знать", "romaji": "znat'", "translation": "to know", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb"], "examples": [{ "text": "Я не знаю.", "romaji": "Ya nye znáyu.", "translation": "I don't know." }] },
  { "schemaVersion": 1, "key": "vocab.ponimat", "entryType": "word", "lemma": "понимать", "romaji": "panimát'", "translation": "to understand", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb"], "examples": [{ "text": "Я не понимаю.", "romaji": "Ya nye panimáyu.", "translation": "I don't understand." }] },
  { "schemaVersion": 1, "key": "vocab.khotet", "entryType": "word", "lemma": "хотеть", "romaji": "khatyét'", "translation": "to want", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb"], "naturalMeaning": "Irregularly conjugated — я хочу, ты хочешь, он хочет, мы хотим, вы хотите, они хотят — worth memorizing as a set rather than deriving from a pattern." },
  { "schemaVersion": 1, "key": "vocab.lyubit", "entryType": "word", "lemma": "любить", "romaji": "lyubít'", "translation": "to like / to love", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb"] },
  { "schemaVersion": 1, "key": "vocab.zvat", "entryType": "word", "lemma": "звать", "romaji": "zvat'", "translation": "to call (by name)", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb"], "naturalMeaning": "Central to introductions: Меня зовут Анна ('My name is Anna', literally 'They call me Anna')." },
  { "schemaVersion": 1, "key": "vocab.zhit", "entryType": "word", "lemma": "жить", "romaji": "zhit'", "translation": "to live", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb"], "examples": [{ "text": "Я живу в Москве.", "romaji": "Ya zhivú v Maskvyé.", "translation": "I live in Moscow." }] },
  { "schemaVersion": 1, "key": "vocab.bolshoy", "entryType": "word", "lemma": "большой", "romaji": "bal'shóy", "translation": "big", "partOfSpeech": "adjective", "cefr": "A1", "register": "neutral", "tags": ["adjective"] },
  { "schemaVersion": 1, "key": "vocab.malenkiy", "entryType": "word", "lemma": "маленький", "romaji": "mályen'kiy", "translation": "small", "partOfSpeech": "adjective", "cefr": "A1", "register": "neutral", "tags": ["adjective"] },
  { "schemaVersion": 1, "key": "vocab.khoroshiy", "entryType": "word", "lemma": "хороший", "romaji": "kharóshiy", "translation": "good", "partOfSpeech": "adjective", "cefr": "A1", "register": "neutral", "tags": ["adjective"] },
  { "schemaVersion": 1, "key": "vocab.plokhoy", "entryType": "word", "lemma": "плохой", "romaji": "plakhóy", "translation": "bad", "partOfSpeech": "adjective", "cefr": "A1", "register": "neutral", "tags": ["adjective"] },
  { "schemaVersion": 1, "key": "vocab.krasivyy", "entryType": "word", "lemma": "красивый", "romaji": "krasívyy", "translation": "beautiful", "partOfSpeech": "adjective", "cefr": "A1", "register": "neutral", "tags": ["adjective"] },
  { "schemaVersion": 1, "key": "vocab.trudnyy", "entryType": "word", "lemma": "трудный", "romaji": "trúdnyy", "translation": "difficult", "partOfSpeech": "adjective", "cefr": "A1", "register": "neutral", "tags": ["adjective"] },
  { "schemaVersion": 1, "key": "vocab.legkiy", "entryType": "word", "lemma": "лёгкий", "romaji": "lyókhkiy", "translation": "easy / light", "partOfSpeech": "adjective", "cefr": "A1", "register": "neutral", "tags": ["adjective"], "pronunciationNotes": "The гк combination is pronounced 'khk', not 'gk' — an irregular cluster shared with a small set of related words." },
  { "schemaVersion": 1, "key": "vocab.dom", "entryType": "word", "lemma": "дом", "romaji": "dom", "translation": "house / home", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "m", "tags": ["places"] },
  { "schemaVersion": 1, "key": "vocab.shkola", "entryType": "word", "lemma": "школа", "romaji": "shkóla", "translation": "school", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "f", "tags": ["places"] },
  { "schemaVersion": 1, "key": "vocab.magazin", "entryType": "word", "lemma": "магазин", "romaji": "magazín", "translation": "shop / store", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "m", "tags": ["places"] },
  { "schemaVersion": 1, "key": "vocab.metro", "entryType": "word", "lemma": "метро", "romaji": "myetró", "translation": "metro / subway", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "n", "tags": ["places", "transport"], "naturalMeaning": "Indeclinable — метро never changes its ending no matter the grammatical case, unlike almost every other Russian noun." },
  { "schemaVersion": 1, "key": "vocab.rabota", "entryType": "word", "lemma": "работа", "romaji": "rabóta", "translation": "work / job", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "f", "tags": ["work"] },
  { "schemaVersion": 1, "key": "vocab.chto", "entryType": "word", "lemma": "что", "romaji": "shto", "translation": "what", "partOfSpeech": "pronoun", "cefr": "A1", "register": "neutral", "tags": ["questions"], "pronunciationNotes": "Spelled with ч but pronounced 'sht' — an irregular spelling-to-sound mismatch shared with a handful of related words (чтобы, ничто)." },
  { "schemaVersion": 1, "key": "vocab.gde", "entryType": "word", "lemma": "где", "romaji": "gdye", "translation": "where", "partOfSpeech": "adverb", "cefr": "A1", "register": "neutral", "tags": ["questions"] },
  { "schemaVersion": 1, "key": "vocab.kto", "entryType": "word", "lemma": "кто", "romaji": "kto", "translation": "who", "partOfSpeech": "pronoun", "cefr": "A1", "register": "neutral", "tags": ["questions"] },
  { "schemaVersion": 1, "key": "vocab.kogda", "entryType": "word", "lemma": "когда", "romaji": "kagdá", "translation": "when", "partOfSpeech": "adverb", "cefr": "A1", "register": "neutral", "tags": ["questions"] },
  { "schemaVersion": 1, "key": "vocab.kak", "entryType": "word", "lemma": "как", "romaji": "kak", "translation": "how", "partOfSpeech": "adverb", "cefr": "A1", "register": "neutral", "tags": ["questions"], "examples": [{ "text": "Как дела?", "romaji": "Kak delá?", "translation": "How are you? (lit. 'how [are your] affairs?')" }] },
  { "schemaVersion": 1, "key": "vocab.pochemu", "entryType": "word", "lemma": "почему", "romaji": "pachemú", "translation": "why", "partOfSpeech": "adverb", "cefr": "A1", "register": "neutral", "tags": ["questions"] }
]
