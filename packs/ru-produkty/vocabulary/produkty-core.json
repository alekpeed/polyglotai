[
  { "schemaVersion": 1, "key": "prdvocab.produktovyy-magazin", "entryType": "phrase", "lemma": "продуктовый магазин", "romaji": "praduktóvyy magazín", "translation": "grocery store", "cefr": "A1", "register": "neutral", "tags": ["store", "core"], "naturalMeaning": "The everyday neighborhood grocery store, smaller and more local than a full супермаркет — often just called 'продуктовый' for short.", "examples": [{ "text": "Рядом с домом есть маленький продуктовый магазин.", "romaji": "Ryádom s dómam yest' mályen'kiy praduktóvyy magazín.", "translation": "There's a small grocery store next to my house." }] },
  { "schemaVersion": 1, "key": "prdvocab.rynok", "entryType": "word", "lemma": "рынок", "romaji": "rýnok", "translation": "open-air market", "partOfSpeech": "noun", "cefr": "A1", "gender": "m", "register": "neutral", "tags": ["store", "core"], "naturalMeaning": "An outdoor or semi-covered market with individual vendor stalls, prized for fresher produce and dairy than a supermarket — see the culture notes on when Russians choose the рынок over a магазин.", "examples": [{ "text": "По субботам мы ходим за овощами на рынок.", "romaji": "Pa subbótam my khódim za óvashchami na rýnak.", "translation": "On Saturdays we go to the market for vegetables." }] },
  { "schemaVersion": 1, "key": "prdvocab.supermarket", "entryType": "word", "lemma": "супермаркет", "romaji": "supermárket", "translation": "supermarket", "partOfSpeech": "noun", "cefr": "A1", "gender": "m", "register": "neutral", "tags": ["store", "core"], "examples": [{ "text": "В супермаркете всё уже упаковано.", "romaji": "V supermárketye vsyo uzhé upakóvana.", "translation": "In the supermarket everything is already packaged." }] },
  { "schemaVersion": 1, "key": "prdvocab.prilavok", "entryType": "word", "lemma": "прилавок", "romaji": "prilávok", "translation": "counter / stall counter", "partOfSpeech": "noun", "cefr": "A2", "gender": "m", "register": "neutral", "tags": ["market"], "naturalMeaning": "The counter or display surface of an individual vendor's stall at a рынок — 'подойти к прилавку' means to walk up to a specific vendor's spot." },
  { "schemaVersion": 1, "key": "prdvocab.larek", "entryType": "word", "lemma": "ларёк", "romaji": "laryók", "translation": "kiosk / small stall", "partOfSpeech": "noun", "cefr": "A2", "gender": "m", "register": "informal", "tags": ["market", "store"], "naturalMeaning": "A small freestanding stand, often on a street corner rather than inside a рынок — sells anything from produce to cigarettes to phone cards." },
  { "schemaVersion": 1, "key": "prdvocab.kilogramm", "entryType": "word", "lemma": "килограмм", "romaji": "kilográmm", "translation": "kilogram", "partOfSpeech": "noun", "cefr": "A1", "gender": "m", "register": "neutral", "tags": ["weight", "core"], "naturalMeaning": "Often shortened in speech to кило, especially with полкило (half a kilo) — the follow-up noun goes in the genitive: килограмм помидоров ('a kilogram of tomatoes').", "examples": [{ "text": "Дайте, пожалуйста, килограмм яблок.", "romaji": "Dáytye, pazhálusta, kilográmm yábluk.", "translation": "Give me a kilogram of apples, please." }] },
  { "schemaVersion": 1, "key": "prdvocab.polkilo", "entryType": "word", "lemma": "полкило", "romaji": "polkiló", "translation": "half a kilo", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "tags": ["weight", "core"], "naturalMeaning": "An indeclinable everyday fusion of пол ('half') and кило — much more natural in speech than saying '500 грамм'." },
  { "schemaVersion": 1, "key": "prdvocab.gramm", "entryType": "word", "lemma": "грамм", "romaji": "gram", "translation": "gram", "partOfSpeech": "noun", "cefr": "A1", "gender": "m", "register": "neutral", "tags": ["weight"], "examples": [{ "text": "Триста грамм творога, пожалуйста.", "romaji": "Trísta gram tvarogá, pazhálusta.", "translation": "Three hundred grams of tvorog, please." }] },
  { "schemaVersion": 1, "key": "prdvocab.pachka", "entryType": "word", "lemma": "пачка", "romaji": "páchka", "translation": "a pack (of something)", "partOfSpeech": "noun", "cefr": "A1", "gender": "f", "register": "neutral", "tags": ["weight", "core"], "naturalMeaning": "The standard unit for pre-packaged goods like творог, масло, or чай — 'пачка творога', 'пачка чая'.", "examples": [{ "text": "Возьму ещё пачку масла.", "romaji": "Voz'mú yeshchó páchku másla.", "translation": "I'll also take a pack of butter." }] },
  { "schemaVersion": 1, "key": "prdvocab.baton", "entryType": "word", "lemma": "батон", "romaji": "batón", "translation": "loaf (of white bread)", "partOfSpeech": "noun", "cefr": "A2", "gender": "m", "register": "neutral", "tags": ["bread"], "naturalMeaning": "Specifically the long white loaf — dark/rye bread is a separate word, буханка." },
  { "schemaVersion": 1, "key": "prdvocab.bukhanka", "entryType": "word", "lemma": "буханка", "romaji": "bukhánka", "translation": "loaf (of dark/rye bread)", "partOfSpeech": "noun", "cefr": "A2", "gender": "f", "register": "neutral", "tags": ["bread"], "examples": [{ "text": "Купи, пожалуйста, буханку чёрного хлеба.", "romaji": "Kupí, pazhálusta, bukhánku chyórnava khlyéba.", "translation": "Please buy a loaf of dark bread." }] },
  { "schemaVersion": 1, "key": "prdvocab.upakovka", "entryType": "word", "lemma": "упаковка", "romaji": "upakóvka", "translation": "package / packaging", "partOfSpeech": "noun", "cefr": "A2", "gender": "f", "register": "neutral", "tags": ["weight"] },
  { "schemaVersion": 1, "key": "prdvocab.shtuka", "entryType": "word", "lemma": "штука", "romaji": "shtúka", "translation": "piece / item (unit)", "partOfSpeech": "noun", "cefr": "A2", "gender": "f", "register": "neutral", "tags": ["weight", "core"], "naturalMeaning": "Used to count individual items sold by the piece rather than by weight — 'три штуки' (three of them), common for things like огурцы or яйца sold loose.", "examples": [{ "text": "Возьму пять штук огурцов.", "romaji": "Voz'mú pyat' shtuk agurtsóv.", "translation": "I'll take five cucumbers (lit. five pieces of cucumber)." }] },
  { "schemaVersion": 1, "key": "prdvocab.litr", "entryType": "word", "lemma": "литр", "romaji": "litr", "translation": "liter", "partOfSpeech": "noun", "cefr": "A1", "gender": "m", "register": "neutral", "tags": ["weight"] },
  { "schemaVersion": 1, "key": "prdvocab.banka", "entryType": "word", "lemma": "банка", "romaji": "bánka", "translation": "jar / can", "partOfSpeech": "noun", "cefr": "A2", "gender": "f", "register": "neutral", "tags": ["weight"], "examples": [{ "text": "Банка сметаны стоит недорого.", "romaji": "Bánka smetány stóit nyedóraga.", "translation": "A jar of sour cream doesn't cost much." }] },
  { "schemaVersion": 1, "key": "prdvocab.molochnye-produkty", "entryType": "phrase", "lemma": "молочные продукты", "romaji": "malóchnyye pradúkty", "translation": "dairy products", "cefr": "A1", "register": "neutral", "tags": ["dairy", "core"], "naturalMeaning": "The umbrella category covering молоко, сметана, кефир, творог, and сыр — usually its own aisle or section in a store." },
  { "schemaVersion": 1, "key": "prdvocab.tvorog", "entryType": "word", "lemma": "творог", "romaji": "tvoróg", "translation": "tvorog (fresh curd cheese / cottage cheese)", "partOfSpeech": "noun", "cefr": "A1", "gender": "m", "register": "neutral", "tags": ["dairy", "core"], "naturalMeaning": "A staple of Russian cooking — eaten plain with sour cream or sugar, or baked into сырники and вареники. Note: both stress patterns творо́г and тво́рог are heard in everyday speech, though dictionaries still list творо́г first.", "examples": [{ "text": "На завтрак у нас творог со сметаной.", "romaji": "Na závtrak u nas tvoróg sa smetánay.", "translation": "For breakfast we're having tvorog with sour cream." }] },
  { "schemaVersion": 1, "key": "prdvocab.smetana", "entryType": "word", "lemma": "сметана", "romaji": "smetána", "translation": "sour cream", "partOfSpeech": "noun", "cefr": "A1", "gender": "f", "register": "neutral", "tags": ["dairy", "core"], "naturalMeaning": "A near-universal topping in Russian cooking — goes on soup, blini, pelmeni, and творог alike." },
  { "schemaVersion": 1, "key": "prdvocab.kefir", "entryType": "word", "lemma": "кефир", "romaji": "kefír", "translation": "kefir", "partOfSpeech": "noun", "cefr": "A2", "gender": "m", "register": "neutral", "tags": ["dairy"], "naturalMeaning": "A tangy fermented milk drink, drunk on its own the way you might drink a glass of milk elsewhere." },
  { "schemaVersion": 1, "key": "prdvocab.grechka", "entryType": "word", "lemma": "гречка", "romaji": "gréchka", "translation": "buckwheat (groats)", "partOfSpeech": "noun", "cefr": "A1", "gender": "f", "register": "neutral", "tags": ["staple", "core"], "naturalMeaning": "The everyday colloquial word for buckwheat groats (formally гречневая крупа) — one of the most common side dishes in Russian cooking, comparable to rice in many other cuisines.", "examples": [{ "text": "Гречка с маслом — простой, но любимый ужин.", "romaji": "Gréchka s máslam — próstoy, no lyubímyy úzhin.", "translation": "Buckwheat with butter is a simple but beloved dinner." }] },
  { "schemaVersion": 1, "key": "prdvocab.ukrop", "entryType": "word", "lemma": "укроп", "romaji": "ukróp", "translation": "dill", "partOfSpeech": "noun", "cefr": "A2", "gender": "m", "register": "neutral", "tags": ["produce", "core"], "naturalMeaning": "Used constantly in Russian cooking, sprinkled over almost anything — soups, potatoes, salads. A market bunch of укроп is one of the cheapest, most reliable buys.", "examples": [{ "text": "Посыпь картошку укропом.", "romaji": "Pasýp' kartóshku ukrópam.", "translation": "Sprinkle dill on the potatoes." }] },
  { "schemaVersion": 1, "key": "prdvocab.petrushka", "entryType": "word", "lemma": "петрушка", "romaji": "petrúshka", "translation": "parsley", "partOfSpeech": "noun", "cefr": "A2", "gender": "f", "register": "neutral", "tags": ["produce"], "naturalMeaning": "Укроп's usual companion herb at a produce stall — also colloquially means 'a whole tricky business/mess' in an unrelated idiom, which sometimes surprises learners." },
  { "schemaVersion": 1, "key": "prdvocab.yaytsa", "entryType": "word", "lemma": "яйца", "romaji": "yáytsa", "translation": "eggs", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "tags": ["staple"], "naturalMeaning": "Plural of яйцо. Market eggs are often sold loose by the piece rather than in a sealed carton — see на развес." },
  { "schemaVersion": 1, "key": "prdvocab.kuritsa", "entryType": "word", "lemma": "курица", "romaji": "kúritsa", "translation": "chicken (meat / hen)", "partOfSpeech": "noun", "cefr": "A1", "gender": "f", "register": "neutral", "tags": ["meat"] },
  { "schemaVersion": 1, "key": "prdvocab.govyadina", "entryType": "word", "lemma": "говядина", "romaji": "gavyádina", "translation": "beef", "partOfSpeech": "noun", "cefr": "A2", "gender": "f", "register": "neutral", "tags": ["meat"] },
  { "schemaVersion": 1, "key": "prdvocab.ryba", "entryType": "word", "lemma": "рыба", "romaji": "rýba", "translation": "fish", "partOfSpeech": "noun", "cefr": "A1", "gender": "f", "register": "neutral", "tags": ["meat", "core"], "examples": [{ "text": "Эта рыба выловлена сегодня утром.", "romaji": "Éta rýba výlavlyena sevódnya útram.", "translation": "This fish was caught this morning." }] },
  { "schemaVersion": 1, "key": "prdvocab.syr", "entryType": "word", "lemma": "сыр", "romaji": "syr", "translation": "cheese", "partOfSpeech": "noun", "cefr": "A1", "gender": "m", "register": "neutral", "tags": ["dairy", "core"] },
  { "schemaVersion": 1, "key": "prdvocab.maslo", "entryType": "word", "lemma": "масло", "romaji": "máslo", "translation": "butter / oil", "partOfSpeech": "noun", "cefr": "A1", "gender": "n", "register": "neutral", "tags": ["dairy"], "naturalMeaning": "Ambiguous without context: сливочное масло is butter, растительное масло is (vegetable) oil." },
  { "schemaVersion": 1, "key": "prdvocab.ovoshchi", "entryType": "word", "lemma": "овощи", "romaji": "óvoshchi", "translation": "vegetables", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "tags": ["produce", "core"] },
  { "schemaVersion": 1, "key": "prdvocab.frukty", "entryType": "word", "lemma": "фрукты", "romaji": "frúkty", "translation": "fruits", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "tags": ["produce", "core"] },
  { "schemaVersion": 1, "key": "prdvocab.yagody", "entryType": "word", "lemma": "ягоды", "romaji": "yágody", "translation": "berries", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "tags": ["produce"], "naturalMeaning": "Russians take real pride in seasonal, regional berries — see the culture notes on seasonal produce pride." },
  { "schemaVersion": 1, "key": "prdvocab.kartoshka", "entryType": "word", "lemma": "картошка", "romaji": "kartóshka", "translation": "potatoes", "partOfSpeech": "noun", "cefr": "A1", "gender": "f", "register": "informal", "tags": ["produce", "core"], "naturalMeaning": "The everyday collective word for potatoes; the formal/dictionary word is картофель (m.), which sounds a bit more official." },
  { "schemaVersion": 1, "key": "prdvocab.ogurets", "entryType": "word", "lemma": "огурец", "romaji": "oguréts", "translation": "cucumber", "partOfSpeech": "noun", "cefr": "A1", "gender": "m", "register": "neutral", "tags": ["produce"] },
  { "schemaVersion": 1, "key": "prdvocab.kapusta", "entryType": "word", "lemma": "капуста", "romaji": "kapústa", "translation": "cabbage", "partOfSpeech": "noun", "cefr": "A1", "gender": "f", "register": "neutral", "tags": ["produce"] },
  { "schemaVersion": 1, "key": "prdvocab.kassa", "entryType": "word", "lemma": "касса", "romaji": "kássa", "translation": "checkout / cash register", "partOfSpeech": "noun", "cefr": "A1", "gender": "f", "register": "neutral", "tags": ["money", "core"], "examples": [{ "text": "Касса номер два свободна.", "romaji": "Kássa nómyer dva svabódna.", "translation": "Checkout number two is free." }] },
  { "schemaVersion": 1, "key": "prdvocab.nalichnye", "entryType": "word", "lemma": "наличные", "romaji": "nalíchnyye", "translation": "cash", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "tags": ["money", "core"], "naturalMeaning": "Used as a plural noun on its own — 'плачу наличными' ('I'm paying in cash'). Cards are widely accepted, but small рынок stalls may still be cash-only.", "examples": [{ "text": "У вас есть наличные?", "romaji": "U vas yest' nalíchnyye?", "translation": "Do you have cash?" }] },
  { "schemaVersion": 1, "key": "prdvocab.sdacha", "entryType": "word", "lemma": "сдача", "romaji": "sdácha", "translation": "change (money handed back)", "partOfSpeech": "noun", "cefr": "A1", "gender": "f", "register": "neutral", "tags": ["money", "core"] },
  { "schemaVersion": 1, "key": "prdvocab.chek", "entryType": "word", "lemma": "чек", "romaji": "chek", "translation": "receipt", "partOfSpeech": "noun", "cefr": "A2", "gender": "m", "register": "neutral", "tags": ["money"] },
  { "schemaVersion": 1, "key": "prdvocab.ochered", "entryType": "word", "lemma": "очередь", "romaji": "óchered'", "translation": "queue / line", "partOfSpeech": "noun", "cefr": "A2", "gender": "f", "register": "neutral", "tags": ["store"], "naturalMeaning": "'Стоять в очереди' (to stand in line) — a familiar experience at a busy касса or a popular rынок stall.", "examples": [{ "text": "Здесь большая очередь на кассу.", "romaji": "Zdyes' balsháya óchered' na kássu.", "translation": "There's a long line at the checkout here." }] },
  { "schemaVersion": 1, "key": "prdvocab.prodavets", "entryType": "word", "lemma": "продавец", "romaji": "prodavéts", "translation": "vendor / seller", "partOfSpeech": "noun", "cefr": "A1", "gender": "m", "register": "neutral", "tags": ["people", "market", "core"], "naturalMeaning": "Feminine form is продавщица. At a рынок, building a relationship with the same продавец over time is common — see the culture notes on trusted regulars." },
  { "schemaVersion": 1, "key": "prdvocab.vzvesit", "entryType": "word", "lemma": "взвесить", "romaji": "vzvésit'", "translation": "to weigh", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb", "market", "core"], "naturalMeaning": "Perfective verb for a single completed act of weighing — what you ask a vendor to do with produce sold на развес.", "examples": [{ "text": "Можете взвесить эти помидоры?", "romaji": "Mózhetye vzvésit' éti pamidóry?", "translation": "Can you weigh these tomatoes?" }] },
  { "schemaVersion": 1, "key": "prdvocab.na-razves", "entryType": "phrase", "lemma": "на развес", "romaji": "na razvés", "translation": "sold by weight (unpackaged)", "cefr": "A2", "register": "neutral", "tags": ["market", "core"], "naturalMeaning": "Describes produce, cheese, and other goods weighed out fresh at the counter rather than sold in a sealed, pre-weighed package — still common at markets and many grocery stores, unlike most Western pre-packaged norms.", "examples": [{ "text": "Этот творог продаётся на развес.", "romaji": "État tvoróg pradayótsya na razvés.", "translation": "This tvorog is sold by weight." }] },
  { "schemaVersion": 1, "key": "prdvocab.svezhiy", "entryType": "word", "lemma": "свежий", "romaji": "svézhiy", "translation": "fresh", "partOfSpeech": "adjective", "cefr": "A1", "register": "neutral", "tags": ["produce", "core"], "examples": [{ "text": "Хлеб сегодня очень свежий.", "romaji": "Khlyep sevódnya óchen' svézhiy.", "translation": "The bread is very fresh today." }] },
  { "schemaVersion": 1, "key": "prdvocab.domashniy", "entryType": "word", "lemma": "домашний", "romaji": "domáshniy", "translation": "homemade / home-grown", "partOfSpeech": "adjective", "cefr": "A2", "register": "neutral", "tags": ["produce", "core"], "naturalMeaning": "High praise at a рынок — домашние овощи (home-grown vegetables) or домашнее молоко signal small-scale, trusted quality rather than mass production." },
  { "schemaVersion": 1, "key": "prdvocab.mestnyy", "entryType": "word", "lemma": "местный", "romaji": "myéstnyy", "translation": "local", "partOfSpeech": "adjective", "cefr": "A2", "register": "neutral", "tags": ["produce", "core"], "naturalMeaning": "Asking whether produce is местный (as opposed to привозной, shipped in from elsewhere) is a normal, expected question at a рынок stall." },
  { "schemaVersion": 1, "key": "prdvocab.skidka-est", "entryType": "phrase", "lemma": "Скидка есть?", "romaji": "Skídka yest'?", "translation": "Is there a discount?", "cefr": "A2", "register": "neutral", "tags": ["phrase", "haggling", "core"], "naturalMeaning": "A mild, everyday way to ask for a bit off the price on a bulk purchase at a рынок — much gentler than aggressive haggling, and easy for a vendor to politely decline. See the culture notes on how bargaining actually works here." },
  { "schemaVersion": 1, "key": "prdvocab.chto-vy-posovetuyete", "entryType": "phrase", "lemma": "Что вы посоветуете?", "romaji": "Shto vy pasavyétuyete?", "translation": "What would you recommend?", "cefr": "A2", "register": "formal", "tags": ["phrase", "market", "core"], "naturalMeaning": "A polite opener with a vendor you don't know yet, using the formal вы — invites a recommendation instead of guessing blind among unfamiliar produce." },
  { "schemaVersion": 1, "key": "prdvocab.mozhno-poprobovat", "entryType": "phrase", "lemma": "Можно попробовать?", "romaji": "Mózhno papróbovat'?", "translation": "May I try it?", "cefr": "A2", "register": "neutral", "tags": ["phrase", "market"], "naturalMeaning": "Common at cheese, honey, and pickle stalls at a рынок, where a small taste before buying is normal and expected — much less so at a supermarket." },
  { "schemaVersion": 1, "key": "prdvocab.skolko-eto-stoit", "entryType": "phrase", "lemma": "Сколько это стоит?", "romaji": "Skól'ko éto stóit?", "translation": "How much does this cost?", "cefr": "A1", "register": "neutral", "tags": ["phrase", "money", "core"] },
  { "schemaVersion": 1, "key": "prdvocab.gde-u-vas", "entryType": "phrase", "lemma": "Где у вас...?", "romaji": "Gdye u vas...?", "translation": "Where do you have...? / Where can I find...?", "cefr": "A1", "register": "formal", "tags": ["phrase", "store", "core"], "naturalMeaning": "The standard way to ask store staff where to find an item — 'Где у вас гречка?' rather than the more literal-sounding 'где гречка находится'." }
]
