[
  { "schemaVersion": 1, "key": "mtvocab.stantsiya", "entryType": "word", "lemma": "станция", "romaji": "stántsiya", "translation": "station", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "f", "tags": ["metro", "core"], "examples": [{ "text": "Это моя станция.", "romaji": "Éta mayá stántsiya.", "translation": "This is my station." }] },
  { "schemaVersion": 1, "key": "mtvocab.liniya", "entryType": "word", "lemma": "линия", "romaji": "líniya", "translation": "line (metro line)", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "f", "tags": ["metro", "core"] },
  { "schemaVersion": 1, "key": "mtvocab.peresadka", "entryType": "word", "lemma": "пересадка", "romaji": "peresátka", "translation": "transfer (between metro lines)", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "gender": "f", "tags": ["metro", "core", "navigation"], "naturalMeaning": "Switching lines within the same station complex, usually via an underground passageway — not exiting to the street.", "examples": [{ "text": "Здесь есть пересадка на кольцевую линию.", "romaji": "Zdyes' yest' peresátka na kal'tsevúyu líniyu.", "translation": "There's a transfer to the circle line here." }] },
  { "schemaVersion": 1, "key": "mtvocab.vkhod", "entryType": "word", "lemma": "вход", "romaji": "fkhot", "translation": "entrance", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "m", "tags": ["metro"] },
  { "schemaVersion": 1, "key": "mtvocab.vykhod", "entryType": "word", "lemma": "выход", "romaji": "výkhat", "translation": "exit", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "m", "tags": ["metro", "core"] },
  { "schemaVersion": 1, "key": "mtvocab.eskalator", "entryType": "word", "lemma": "эскалатор", "romaji": "eskalátor", "translation": "escalator", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "m", "tags": ["metro", "core"], "naturalMeaning": "Moscow's deep stations have some of the longest escalators in the world — a few run over 100 meters and take two to three minutes to ride." },
  { "schemaVersion": 1, "key": "mtvocab.poyezd", "entryType": "word", "lemma": "поезд", "romaji": "póyezt", "translation": "train", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "m", "tags": ["metro"] },
  { "schemaVersion": 1, "key": "mtvocab.vagon", "entryType": "word", "lemma": "вагон", "romaji": "vagón", "translation": "train car, carriage", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "gender": "m", "tags": ["metro"] },
  { "schemaVersion": 1, "key": "mtvocab.platforma", "entryType": "word", "lemma": "платформа", "romaji": "platfórma", "translation": "platform", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "f", "tags": ["metro"] },
  { "schemaVersion": 1, "key": "mtvocab.skhema-metro", "entryType": "phrase", "lemma": "схема метро", "romaji": "skhéma myetró", "translation": "metro map", "cefr": "A1", "register": "neutral", "tags": ["metro", "navigation", "core"], "naturalMeaning": "The color-coded line diagram posted in every car and station — locals navigate by line color and station name, not compass direction." },
  { "schemaVersion": 1, "key": "mtvocab.tsentr", "entryType": "word", "lemma": "центр", "romaji": "tsentr", "translation": "center, downtown", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "gender": "m", "tags": ["metro", "navigation"], "naturalMeaning": "Radial metro lines run between downtown and the outskirts, so \"в центр\" (toward downtown) and \"от центра\" (away from downtown) are the two directions every line is described by — see the culture notes on the announcement-voice convention." },
  { "schemaVersion": 1, "key": "mtvocab.koltsevaya-liniya", "entryType": "phrase", "lemma": "кольцевая линия", "romaji": "kal'tsevája líniya", "translation": "circle line (the Moscow metro's ring line)", "cefr": "A2", "register": "neutral", "tags": ["metro", "core"], "naturalMeaning": "The brown ring line (Line 5) connecting nearly all the radial lines — several of its stations, including Комсомольская, are among the most ornately decorated in the whole system." },
  { "schemaVersion": 1, "key": "mtvocab.ostorozhno-dveri-zakryvayutsya", "entryType": "chunk", "lemma": "Осторожно, двери закрываются.", "romaji": "Astarózhna, dvyéri zakryváyutsya.", "translation": "Careful, the doors are closing.", "register": "neutral", "cefr": "A2", "tags": ["metro", "announcement", "core"], "naturalMeaning": "The single most recognized phrase in the Moscow metro — announced before every departure, almost always followed immediately by \"Следующая станция —\". Riders repeat it as a joke or a catchphrase far beyond the platform." },
  { "schemaVersion": 1, "key": "mtvocab.sleduyushchaya-stantsiya", "entryType": "chunk", "lemma": "Следующая станция —", "romaji": "Slyéduyushchaya stántsiya —", "translation": "The next station is —", "register": "neutral", "cefr": "A2", "tags": ["metro", "announcement", "core"], "naturalMeaning": "Completed by the station name over the speakers right after the doors-closing warning — a male voice announces this on trains heading toward the center, a female voice on trains heading away from it (see culture notes)." },
  { "schemaVersion": 1, "key": "mtvocab.turniket", "entryType": "word", "lemma": "турникет", "romaji": "turnikét", "translation": "turnstile", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "m", "tags": ["metro", "payment", "core"] },
  { "schemaVersion": 1, "key": "mtvocab.proyezdnoy", "entryType": "word", "lemma": "проездной", "romaji": "prayezdnóy", "translation": "travel pass (multi-ride or period pass)", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "gender": "m", "tags": ["metro", "payment", "core"], "naturalMeaning": "Short for проездной билет — sold for a fixed number of rides or a fixed period (a week, a month), unlike a single-ride ticket." },
  { "schemaVersion": 1, "key": "mtvocab.transportnaya-karta", "entryType": "phrase", "lemma": "транспортная карта", "romaji": "transpórtnaya kárta", "translation": "transit card (rechargeable travel card)", "cefr": "A2", "register": "neutral", "tags": ["payment"], "naturalMeaning": "The generic term for any rechargeable smart transit card — useful if you've forgotten the brand name (see Тройка below)." },
  { "schemaVersion": 1, "key": "mtvocab.troyka", "entryType": "word", "lemma": "Тройка", "romaji": "Tróyka", "translation": "Troika (Moscow's rechargeable transit card)", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "gender": "f", "tags": ["payment", "core"], "naturalMeaning": "Literally \"a set of three\" (also the classic three-horse sleigh) — the actual brand name of Moscow's transit card, accepted on the metro, buses, and most marshrutky.", "examples": [{ "text": "Приложите Тройку к турникету.", "romaji": "Prilazhýte Tróyku k turnikétu.", "translation": "Tap your Troika card on the turnstile." }] },
  { "schemaVersion": 1, "key": "mtvocab.zheton", "entryType": "word", "lemma": "жетон", "romaji": "zhetón", "translation": "token (single-ride metro token)", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "gender": "m", "tags": ["metro", "payment"], "naturalMeaning": "Small plastic tokens are still sold for cash at manned kiosks, though most riders now tap a card or phone instead." },
  { "schemaVersion": 1, "key": "mtvocab.popolnit", "entryType": "word", "lemma": "пополнить", "romaji": "papólnit'", "translation": "to top up (a card's balance)", "partOfSpeech": "verb", "cefr": "A2", "register": "neutral", "tags": ["payment"], "examples": [{ "text": "Где можно пополнить карту?", "romaji": "Gdye mózhna papólnit' kártu?", "translation": "Where can I top up my card?" }] },
  { "schemaVersion": 1, "key": "mtvocab.balans", "entryType": "word", "lemma": "баланс", "romaji": "baláns", "translation": "balance (card balance)", "partOfSpeech": "noun", "cefr": "B1", "register": "neutral", "gender": "m", "tags": ["payment"] },
  { "schemaVersion": 1, "key": "mtvocab.kassa", "entryType": "word", "lemma": "касса", "romaji": "kássa", "translation": "ticket booth, kiosk", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "f", "tags": ["metro", "payment"] },
  { "schemaVersion": 1, "key": "mtvocab.bilet", "entryType": "word", "lemma": "билет", "romaji": "bilyét", "translation": "ticket", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "m", "tags": ["metro", "payment", "core"] },
  { "schemaVersion": 1, "key": "mtvocab.kontroler", "entryType": "word", "lemma": "контролёр", "romaji": "kantralyór", "translation": "ticket inspector", "partOfSpeech": "noun", "cefr": "B1", "register": "neutral", "gender": "m", "tags": ["payment"], "naturalMeaning": "Metro turnstiles gate entry so inspections are rare there, but random fare checks by a контролёр are a real possibility on buses and some marshrutky." },
  { "schemaVersion": 1, "key": "mtvocab.marshrutka", "entryType": "word", "lemma": "маршрутка", "romaji": "marshrútka", "translation": "marshrutka (shared minibus)", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "f", "tags": ["marshrutka", "core"], "naturalMeaning": "Short for маршрутное такси (\"route taxi\") — a fixed-route minibus, faster and more flexible than a city bus but not hailed like a street taxi; you board it at a stop and pay for a seat.", "examples": [{ "text": "Маршрутка идёт до вокзала.", "romaji": "Marshrútka idyót da vakzála.", "translation": "The marshrutka goes to the train station." }] },
  { "schemaVersion": 1, "key": "mtvocab.voditel", "entryType": "word", "lemma": "водитель", "romaji": "vadítel'", "translation": "driver", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "m", "tags": ["marshrutka", "core"] },
  { "schemaVersion": 1, "key": "mtvocab.peredat", "entryType": "word", "lemma": "передать", "romaji": "peredát'", "translation": "to pass (something) along, forward", "partOfSpeech": "verb", "cefr": "A2", "register": "neutral", "tags": ["marshrutka", "core"], "naturalMeaning": "The verb behind the marshrutka fare-passing custom: since the driver can't reach every seat, passengers hand money forward from stranger to stranger until it reaches the front, and change comes back the same way." },
  { "schemaVersion": 1, "key": "mtvocab.peredayte-pozhaluysta", "entryType": "phrase", "lemma": "Передайте, пожалуйста.", "romaji": "Peredáyte, pazhálusta.", "translation": "Please pass this along.", "register": "neutral", "cefr": "A2", "tags": ["marshrutka", "core"], "naturalMeaning": "Said while handing money forward toward the driver — the person who receives it simply repeats the gesture to the next passenger without comment." },
  { "schemaVersion": 1, "key": "mtvocab.za-proyezd", "entryType": "phrase", "lemma": "за проезд", "romaji": "za prayézd", "translation": "for the fare, for the ride", "cefr": "A2", "register": "neutral", "tags": ["marshrutka", "payment", "core"], "naturalMeaning": "The standard way to specify what the passed-forward money is for: \"За проезд, передайте, пожалуйста\" — \"For the fare, please pass it along.\"" },
  { "schemaVersion": 1, "key": "mtvocab.sdacha", "entryType": "word", "lemma": "сдача", "romaji": "zdácha", "translation": "change (money returned)", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "gender": "f", "tags": ["marshrutka", "payment", "core"], "naturalMeaning": "Passed hand-to-hand back down the aisle the same trust-based way the fare went forward — nobody counts it in front of strangers, and it always arrives." },
  { "schemaVersion": 1, "key": "mtvocab.ostanovite-zdes", "entryType": "phrase", "lemma": "Остановите здесь, пожалуйста.", "romaji": "Astanavíte zdyes', pazhálusta.", "translation": "Please stop here.", "register": "formal", "cefr": "A2", "tags": ["marshrutka", "core"], "naturalMeaning": "Marshrutky often stop wherever a passenger asks rather than only at fixed stops — call this out a little before your spot, since the driver won't wait for you to finish speaking before braking." },
  { "schemaVersion": 1, "key": "mtvocab.po-trebovaniyu", "entryType": "phrase", "lemma": "по требованию", "romaji": "pa trébavaniyu", "translation": "on request, stop-on-request", "cefr": "B1", "register": "neutral", "tags": ["marshrutka", "navigation"], "naturalMeaning": "Seen on signs as \"остановка по требованию\" — a stop the vehicle only pulls into if a rider inside asks or someone at the curb signals." },
  { "schemaVersion": 1, "key": "mtvocab.sleduyushchaya-ostanovka", "entryType": "phrase", "lemma": "следующая остановка", "romaji": "slyéduyushchaya astanófka", "translation": "the next stop", "cefr": "A2", "register": "neutral", "tags": ["marshrutka", "navigation", "core"] },
  { "schemaVersion": 1, "key": "mtvocab.eto-moya-ostanovka", "entryType": "phrase", "lemma": "Это моя остановка.", "romaji": "Éta mayá astanófka.", "translation": "This is my stop.", "register": "neutral", "cefr": "A2", "tags": ["marshrutka", "core"] },
  { "schemaVersion": 1, "key": "mtvocab.ostanovka", "entryType": "word", "lemma": "остановка", "romaji": "astanófka", "translation": "stop (bus or marshrutka stop)", "partOfSpeech": "noun", "cefr": "A1", "register": "neutral", "gender": "f", "tags": ["marshrutka", "navigation", "core"] },
  { "schemaVersion": 1, "key": "mtvocab.raspisaniye", "entryType": "word", "lemma": "расписание", "romaji": "raspisániye", "translation": "schedule", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "gender": "n", "tags": ["navigation"] },
  { "schemaVersion": 1, "key": "mtvocab.kakaya-sleduyushchaya-stantsiya", "entryType": "phrase", "lemma": "Какая следующая станция?", "romaji": "Kakáya slyéduyushchaya stántsiya?", "translation": "What's the next station?", "register": "neutral", "cefr": "A1", "tags": ["metro", "navigation", "core"] },
  { "schemaVersion": 1, "key": "mtvocab.kak-proyti-k-vykhodu", "entryType": "phrase", "lemma": "Как пройти к выходу?", "romaji": "Kak praytí k výkhadu?", "translation": "How do I get to the exit?", "register": "formal", "cefr": "A2", "tags": ["metro", "navigation", "core"] },
  { "schemaVersion": 1, "key": "mtvocab.na-kakoy-stantsii-mne-vykhodit", "entryType": "phrase", "lemma": "На какой станции мне выходить?", "romaji": "Na kakóy stántsii mnye vykhadít'?", "translation": "At which station should I get off?", "register": "formal", "cefr": "A2", "tags": ["metro", "navigation", "core"] },
  { "schemaVersion": 1, "key": "mtvocab.podskazhite-pozhaluysta", "entryType": "phrase", "lemma": "Подскажите, пожалуйста.", "romaji": "Patskazhýte, pazhálusta.", "translation": "Could you tell me, please...", "register": "formal", "cefr": "A2", "tags": ["navigation", "core"], "naturalMeaning": "An all-purpose polite opener for asking a stranger anything, softer than a bare question — used constantly before asking for directions or the next stop." },
  { "schemaVersion": 1, "key": "mtvocab.ya-zabludilsya", "entryType": "phrase", "lemma": "Я заблудился. / Я заблудилась.", "romaji": "Ya zabludílsya. / Ya zabludílas'.", "translation": "I'm lost.", "register": "neutral", "cefr": "A2", "tags": ["navigation"], "naturalMeaning": "Past-tense verbs agree with the speaker's gender — заблудился if you're male, заблудилась if you're female; there's no gender-neutral third option in the standard past tense." },
  { "schemaVersion": 1, "key": "mtvocab.mne-nuzhno-na", "entryType": "phrase", "lemma": "Мне нужно на ...", "romaji": "Mnye núzhna na ...", "translation": "I need to get to (station name).", "register": "neutral", "cefr": "A2", "tags": ["metro", "navigation", "core"], "examples": [{ "text": "Мне нужно на Комсомольскую.", "romaji": "Mnye núzhna na Kamsamól'skuyu.", "translation": "I need to get to Komsomolskaya." }] },
  { "schemaVersion": 1, "key": "mtvocab.perekhod", "entryType": "word", "lemma": "переход", "romaji": "perekhót", "translation": "passageway, connecting corridor (between lines or to the street)", "partOfSpeech": "noun", "cefr": "B1", "register": "neutral", "gender": "m", "tags": ["metro", "navigation"] },
  { "schemaVersion": 1, "key": "mtvocab.napravleniye", "entryType": "word", "lemma": "направление", "romaji": "napravlyéniye", "translation": "direction", "partOfSpeech": "noun", "cefr": "A2", "register": "neutral", "gender": "n", "tags": ["metro", "navigation"] },
  { "schemaVersion": 1, "key": "mtvocab.pervyy-vagon", "entryType": "phrase", "lemma": "первый вагон", "romaji": "pyérvyy vagón", "translation": "the first car (of the train)", "cefr": "A2", "register": "neutral", "tags": ["metro", "navigation"], "naturalMeaning": "Announcements and platform signs often reference the train by car number — \"выход в город из последнего вагона\" (exit to the street from the last car) tells you exactly where to stand before the doors open." }
]
