# Optional — builds default to the shared production proxy (see DEFAULT_PROXY_BASE_URL in
# apps/desktop-tauri/src/ai/aiContext.ts). Only set this to point a build at your own
# supabase/functions/openai-proxy deploy instead — see supabase/README.md for the deploy steps.
VITE_AI_PROXY_URL=https://YOUR-PROJECT-REF.supabase.co/functions/v1/openai-proxy

# Accounts (login/signup, cloud-synced progress) — from Supabase dashboard → Settings → API.
# The anon/public key is meant to be public; row-level security is what actually protects data,
# never put the service_role key here or anywhere client-side.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
