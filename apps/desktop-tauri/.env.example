# Copy to .env.local (gitignored) and fill in after deploying supabase/functions/openai-proxy
# — see supabase/README.md for the deploy steps. Without this set, AI features (Tutor,
# Conversation, Live Interpreter, Pronunciation) are simply unavailable in this build; every
# other screen works fine regardless.
VITE_AI_PROXY_URL=https://YOUR-PROJECT-REF.supabase.co/functions/v1/openai-proxy
